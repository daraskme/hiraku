# ─── Google Sign-In + クラウド同期 ───
# Astro ビルド時に <meta>/JS に埋め込む公開クライアント ID。
# Google Cloud Console → APIs & Services → Credentials で
# 「OAuth 2.0 Client ID (Web application)」を作成し、ここに貼る。
# 値は公開値であって秘密ではないが、リダイレクト URL / Origin は登録必須。
#
# 詳細手順は SETUP.md を参照。
PUBLIC_GOOGLE_CLIENT_ID=

# Cloudflare Pages Functions 用 (wrangler.toml の [vars] から読まれる)。
# ローカル開発で wrangler pages dev を使う場合のみ意味を持つ。
# 本番では Cloudflare ダッシュボード上で環境変数として設定する。
GOOGLE_CLIENT_ID=
SESSION_TTL_DAYS=30
