---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const kokugo3 = (await getCollection('kokugo3')).sort((a, b) => a.data.order - b.data.order);
const chugaku1 = (await getCollection('chugaku1')).sort((a, b) => a.data.order - b.data.order);
const kotoko1 = (await getCollection('kotoko1')).sort((a, b) => a.data.order - b.data.order);
const chugakurika1 = (await getCollection('chugakurika1')).sort((a, b) => a.data.order - b.data.order);
const kotokoeigo1 = (await getCollection('kotokoeigo1')).sort((a, b) => a.data.order - b.data.order);
const sansu5 = (await getCollection('sansu5')).sort((a, b) => a.data.order - b.data.order);
---

<Base title="ライブラリ" description="教材一覧" wide>
  <section class="section">
    <div class="section__heading">
      <h1>ライブラリ</h1>
      <span class="section__subtitle">LIBRARY</span>
    </div>
    <p>
      現行学習指導要領（平成29年告示）に対応する教材を、教科・学年ごとに収載しています。
      新しい教材は順次追加していきます。
    </p>
  </section>

  <section class="section">
    <div class="section__heading">
      <h2>小学校 国語 第3学年</h2>
      <span class="section__subtitle">小3 ・ 国語</span>
    </div>

    {kokugo3.length === 0 ? (
      <div class="empty-state">
        <h3>準備中です</h3>
      </div>
    ) : (
      <div class="lesson-grid">
        {kokugo3.map((lesson) => (
          <article class="lesson-card">
            <a href={`/library/kokugo3/${lesson.id}`} class="lesson-card__link">
              <p class="lesson-card__meta">
                {lesson.data.domains[0] || `第${lesson.data.grade}学年`}
                {lesson.data.estimated_minutes && ` ・ ${lesson.data.estimated_minutes} 分`}
              </p>
              <h3 class="lesson-card__title">{lesson.data.title}</h3>
              <p class="lesson-card__desc">{lesson.data.description}</p>
              <p class="lesson-card__author">
                {lesson.data.author}
                {lesson.data.original_year && `（${lesson.data.original_year}）`}
              </p>
            </a>
          </article>
        ))}
      </div>
    )}
  </section>

  <section class="section">
    <div class="section__heading">
      <h2>小学校 算数 第5学年</h2>
      <span class="section__subtitle">小5 ・ 算数</span>
    </div>

    {sansu5.length === 0 ? (
      <div class="empty-state">
        <h3>準備中です</h3>
      </div>
    ) : (
      <div class="lesson-grid">
        {sansu5.map((lesson) => (
          <article class="lesson-card">
            <a href={`/library/sansu5/${lesson.id}`} class="lesson-card__link">
              <p class="lesson-card__meta">
                和算
                {lesson.data.estimated_minutes && ` ・ ${lesson.data.estimated_minutes} 分`}
              </p>
              <h3 class="lesson-card__title">{lesson.data.title}</h3>
              <p class="lesson-card__desc">{lesson.data.description}</p>
              <p class="lesson-card__author">
                {lesson.data.author}
                {lesson.data.original_year && `（${lesson.data.original_year}）`}
              </p>
            </a>
          </article>
        ))}
      </div>
    )}
  </section>

  <section class="section">
    <div class="section__heading">
      <h2>中学校 理科 第1学年</h2>
      <span class="section__subtitle">中1 ・ 理科</span>
    </div>

    {chugakurika1.length === 0 ? (
      <div class="empty-state">
        <h3>準備中です</h3>
      </div>
    ) : (
      <div class="lesson-grid">
        {chugakurika1.map((lesson) => (
          <article class="lesson-card">
            <a href={`/library/chugakurika1/${lesson.id}`} class="lesson-card__link">
              <p class="lesson-card__meta">
                科学随筆
                {lesson.data.estimated_minutes && ` ・ ${lesson.data.estimated_minutes} 分`}
              </p>
              <h3 class="lesson-card__title">{lesson.data.title}</h3>
              <p class="lesson-card__desc">{lesson.data.description}</p>
              <p class="lesson-card__author">
                {lesson.data.author}
                {lesson.data.original_year && `（${lesson.data.original_year}）`}
              </p>
            </a>
          </article>
        ))}
      </div>
    )}
  </section>

  <section class="section">
    <div class="section__heading">
      <h2>中学校 国語 第1学年</h2>
      <span class="section__subtitle">中1 ・ 国語</span>
    </div>

    {chugaku1.length === 0 ? (
      <div class="empty-state">
        <h3>準備中です</h3>
      </div>
    ) : (
      <div class="lesson-grid">
        {chugaku1.map((lesson) => (
          <article class="lesson-card">
            <a href={`/library/chugaku1/${lesson.id}`} class="lesson-card__link">
              <p class="lesson-card__meta">
                {lesson.data.classical ? '古典 ・ ' : ''}
                {lesson.data.domains[0] || `第${lesson.data.grade}学年`}
                {lesson.data.estimated_minutes && ` ・ ${lesson.data.estimated_minutes} 分`}
              </p>
              <h3 class="lesson-card__title">{lesson.data.title}</h3>
              <p class="lesson-card__desc">{lesson.data.description}</p>
              <p class="lesson-card__author">
                {lesson.data.author}
                {lesson.data.era ? `（${lesson.data.era}）` : lesson.data.original_year ? `（${lesson.data.original_year}）` : ''}
              </p>
            </a>
          </article>
        ))}
      </div>
    )}
  </section>

  <section class="section">
    <div class="section__heading">
      <h2>高等学校 英語 第1学年</h2>
      <span class="section__subtitle">高1 ・ 英語</span>
    </div>

    {kotokoeigo1.length === 0 ? (
      <div class="empty-state">
        <h3>準備中です</h3>
      </div>
    ) : (
      <div class="lesson-grid">
        {kotokoeigo1.map((lesson) => (
          <article class="lesson-card">
            <a href={`/library/kotokoeigo1/${lesson.id}`} class="lesson-card__link">
              <p class="lesson-card__meta">
                Reading
                {lesson.data.estimated_minutes && ` ・ ${lesson.data.estimated_minutes} min`}
              </p>
              <h3 class="lesson-card__title">{lesson.data.title}</h3>
              <p class="lesson-card__desc">{lesson.data.description}</p>
              <p class="lesson-card__author">
                {lesson.data.author}
                {lesson.data.original_year && `（${lesson.data.original_year}）`}
              </p>
            </a>
          </article>
        ))}
      </div>
    )}
  </section>

  <section class="section">
    <div class="section__heading">
      <h2>高等学校 国語 第1学年</h2>
      <span class="section__subtitle">高1 ・ 国語</span>
    </div>

    {kotoko1.length === 0 ? (
      <div class="empty-state">
        <h3>準備中です</h3>
      </div>
    ) : (
      <div class="lesson-grid">
        {kotoko1.map((lesson) => (
          <article class="lesson-card">
            <a href={`/library/kotoko1/${lesson.id}`} class="lesson-card__link">
              <p class="lesson-card__meta">
                {lesson.data.classical ? '古典 ・ ' : ''}
                {lesson.data.domains[0] || `第${lesson.data.grade}学年`}
                {lesson.data.estimated_minutes && ` ・ ${lesson.data.estimated_minutes} 分`}
              </p>
              <h3 class="lesson-card__title">{lesson.data.title}</h3>
              <p class="lesson-card__desc">{lesson.data.description}</p>
              <p class="lesson-card__author">
                {lesson.data.author}
                {lesson.data.era ? `（${lesson.data.era}）` : lesson.data.original_year ? `（${lesson.data.original_year}）` : ''}
              </p>
            </a>
          </article>
        ))}
      </div>
    )}
  </section>
</Base>
