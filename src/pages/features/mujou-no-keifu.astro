    .feature section { margin: 1.8rem 0; }
    .feature h2 { font-family: var(--font-serif); font-size: 1.2rem; border-left: 3px solid var(--accent); padding-left: 0.5rem; }
    .feature blockquote {
      padding: 0.8rem 1.2rem;
      background: var(--bg-soft);
      border-left: 3px solid var(--accent);
