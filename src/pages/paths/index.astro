---
import Base from '../../layouts/Base.astro';
import { PATHS } from '../../data/paths';

const ACCENT_COLOR: Record<string, string> = {
  amber: '#c97a3e',
  rose: '#a8485c',
  indigo: '#3e7ec9',
  teal: '#3eae8f',
  lime: '#7ea83e',
  violet: '#7a5ec9',
};
---

<Base
  title="学習パス"
  description="教材を順序立てた推奨ルート。テーマや時代軸で、次に何を読むかの道しるべ。"
  wide
>
  <section class="section">
    <div class="section__heading">
      <h1>学習パス</h1>
      <span class="section__subtitle">PATHS</span>
    </div>
    <p>
      ひらくの教材を、テーマ・時代・難易度の軸で順序立てた<strong>推奨ルート</strong>。
      授業の単元計画や、自学の道しるべとしてご活用ください。
    </p>
    <p class="cross-links no-print">
      別の切り口で探す：
      <a href="/library">教科・学年別ライブラリ</a> ・
      <a href="/timeline">時代年表</a> ・
      <a href="/curriculum">学習指導要領索引</a>
    </p>
  </section>

  <section class="section">
    <div class="paths-grid">
      {PATHS.map((p) => (
        <article class="path-card" style={`--path-accent: ${ACCENT_COLOR[p.accent]}`}>
          <a href={`/paths/${p.id}`}>
            <div class="path-card__meta">
              <span class="path-card__stage">{p.stage}</span>
              <span class="path-card__diff">{p.difficulty}</span>
              <span class="path-card__time">約 {p.estimated_total_minutes} 分</span>
            </div>
            <h2 class="path-card__title">{p.title}</h2>
            {p.subtitle && <p class="path-card__subtitle">{p.subtitle}</p>}
            <p class="path-card__desc">{p.description}</p>
            <div class="path-card__chips">
              {p.steps.slice(0, 3).map((s, i) => (
                <span class="path-card__chip">
                  <span class="path-card__chip-num">{i + 1}</span>
                  {s.id}
                </span>
              ))}
              {p.steps.length > 3 && <span class="path-card__more">+ あと {p.steps.length - 3} 教材</span>}
            </div>
            <p class="path-card__cta">
              パスを開く →
            </p>
          </a>
        </article>
      ))}
    </div>
  </section>

  <style>
    .cross-links a {
      color: var(--accent);
      text-decoration: underline;
      text-decoration-style: dotted;
      text-underline-offset: 3px;
    }

    .paths-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 1rem;
    }
    .path-card {
      border-radius: 10px;
      overflow: hidden;
      background: var(--bg-soft);
      border: 1px solid var(--border);
      border-left: 4px solid var(--path-accent, var(--accent));
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .path-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
    }
    .path-card a {
      display: block;
      padding: 1.2rem;
      color: inherit;
      text-decoration: none;
    }
    .path-card__meta {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
      margin-bottom: 0.4rem;
      font-size: 0.75rem;
      color: var(--text-soft);
    }
    .path-card__stage, .path-card__diff, .path-card__time {
      padding: 0.1rem 0.5rem;
      border-radius: 999px;
      background: var(--bg);
      border: 1px solid var(--border);
      font-variant-numeric: tabular-nums;
    }
    .path-card__title {
      margin: 0 0 0.2rem;
      font-size: 1.15rem;
      color: var(--text);
    }
    .path-card__subtitle {
      margin: 0 0 0.6rem;
      font-size: 0.88rem;
      color: var(--path-accent, var(--accent));
      font-weight: 500;
    }
    .path-card__desc {
      margin: 0 0 0.8rem;
      font-size: 0.92rem;
      line-height: 1.6;
      color: var(--text);
    }
    .path-card__chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.3rem;
      margin-bottom: 0.6rem;
    }
    .path-card__chip {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.15rem 0.5rem;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 999px;
      font-size: 0.7rem;
      color: var(--text-soft);
      font-family: var(--font-mono);
    }
    .path-card__chip-num {
      width: 18px;
      height: 18px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--path-accent, var(--accent));
      color: white;
      border-radius: 50%;
      font-size: 0.62rem;
      font-weight: 600;
    }
    .path-card__more {
      font-size: 0.72rem;
      color: var(--text-soft);
      align-self: center;
    }
    .path-card__cta {
      margin: 0;
      font-size: 0.88rem;
      color: var(--path-accent, var(--accent));
      font-weight: 500;
    }
  </style>
</Base>
