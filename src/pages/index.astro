---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const kokugo3 = (await getCollection('kokugo3')).map((l) => ({ collection: 'kokugo3', ...l }));
const kokugo4 = (await getCollection('kokugo4')).map((l) => ({ collection: 'kokugo4', ...l }));
const kokugo6 = (await getCollection('kokugo6')).map((l) => ({ collection: 'kokugo6', ...l }));
const chugaku1 = (await getCollection('chugaku1')).map((l) => ({ collection: 'chugaku1', ...l }));
const chugaku2 = (await getCollection('chugaku2')).map((l) => ({ collection: 'chugaku2', ...l }));
const chugaku3 = (await getCollection('chugaku3')).map((l) => ({ collection: 'chugaku3', ...l }));
const kotoko1 = (await getCollection('kotoko1')).map((l) => ({ collection: 'kotoko1', ...l }));
const kotoko2 = (await getCollection('kotoko2')).map((l) => ({ collection: 'kotoko2', ...l }));
const kateika5 = (await getCollection('kateika5')).map((l) => ({ collection: 'kateika5', ...l }));
const chugakurika1 = (await getCollection('chugakurika1')).map((l) => ({ collection: 'chugakurika1', ...l }));
const chugakurika2 = (await getCollection('chugakurika2')).map((l) => ({ collection: 'chugakurika2', ...l }));
const chugakurekishi1 = (await getCollection('chugakurekishi1')).map((l) => ({ collection: 'chugakurekishi1', ...l }));
const kotokoeigo1 = (await getCollection('kotokoeigo1')).map((l) => ({ collection: 'kotokoeigo1', ...l }));
const sansu5 = (await getCollection('sansu5')).map((l) => ({ collection: 'sansu5', ...l }));
const chugakukomin3 = (await getCollection('chugakukomin3')).map((l) => ({ collection: 'chugakukomin3', ...l }));
const kotorekishi1 = (await getCollection('kotorekishi1')).map((l) => ({ collection: 'kotorekishi1', ...l }));
const kotokokanbun1 = (await getCollection('kotokokanbun1')).map((l) => ({ collection: 'kotokokanbun1', ...l }));
const kotosekaishi1 = (await getCollection('kotosekaishi1')).map((l) => ({ collection: 'kotosekaishi1', ...l }));
const chugakusugaku1 = (await getCollection('chugakusugaku1')).map((l) => ({ collection: 'chugakusugaku1', ...l }));
const sansu4 = (await getCollection('sansu4')).map((l) => ({ collection: 'sansu4', ...l }));
const ongaku1 = (await getCollection('ongaku1')).map((l) => ({ collection: 'ongaku1', ...l }));
const chugakusugaku2 = (await getCollection('chugakusugaku2')).map((l) => ({ collection: 'chugakusugaku2', ...l }));
const chugakusugaku3 = (await getCollection('chugakusugaku3')).map((l) => ({ collection: 'chugakusugaku3', ...l }));
const seibutsu1 = (await getCollection('seibutsu1')).map((l) => ({ collection: 'seibutsu1', ...l }));
const kagaku1 = (await getCollection('kagaku1')).map((l) => ({ collection: 'kagaku1', ...l }));
const butsuri1 = (await getCollection('butsuri1')).map((l) => ({ collection: 'butsuri1', ...l }));
const chigaku1 = (await getCollection('chigaku1')).map((l) => ({ collection: 'chigaku1', ...l }));
const bijutsu1 = (await getCollection('bijutsu1')).map((l) => ({ collection: 'bijutsu1', ...l }));
const taiiku1 = (await getCollection('taiiku1')).map((l) => ({ collection: 'taiiku1', ...l }));
const doutoku1 = (await getCollection('doutoku1')).map((l) => ({ collection: 'doutoku1', ...l }));
const jouhou1 = (await getCollection('jouhou1')).map((l) => ({ collection: 'jouhou1', ...l }));
const allLessons = [...kokugo3, ...kokugo4, ...kokugo6, ...chugaku1, ...chugaku2, ...chugaku3, ...kotoko1, ...kotoko2, ...kateika5, ...chugakurika1, ...chugakurika2, ...chugakurekishi1, ...kotokoeigo1, ...sansu5, ...chugakukomin3, ...kotorekishi1, ...kotokokanbun1, ...kotosekaishi1, ...chugakusugaku1, ...sansu4, ...ongaku1, ...chugakusugaku2, ...chugakusugaku3, ...seibutsu1, ...kagaku1, ...butsuri1, ...chigaku1, ...bijutsu1, ...taiiku1, ...doutoku1, ...jouhou1];
const featured = [...allLessons]
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);

// 今日の一篇: クライアントサイドで利用日付に基づいて選出するためのデータ
// (ビルド時点では全候補をコンパクトに JSON にしておき、JS が日付ハッシュで 1 件決める)
const dailyCandidates = allLessons.map((l) => ({
  path: `/library/${l.collection}/${l.id}`,
  title: l.data.title,
  author: l.data.author,
  description: l.data.description,
  collection: l.collection,
  year: l.data.original_year,
  era: l.data.era,
}));
---

<Base
  title="ひらく"
  description="著作権が切れた日本語教科書素材を、現行学習指導要領（平成29年告示）に沿って再編集して公開するオープン教材プロジェクト"
  wide
  hrefAlt="/en/"
>
  <section class="hero">
    <p class="hero__eyebrow">無料 ・ オープンソース ・ CC BY-SA</p>
    <h1 class="hero__title">みんなの教科書を、<br />ふたたび<span class="accent">ひらく</span>。</h1>
    <p class="hero__lead">
      明治から平成までの日本語教科書を、現代の<strong>学習指導要領</strong>に
      合わせて編集。すべての人に、自由でひらかれた学びの道具を。
    </p>
    <div class="hero__ctas">
      <a href="/library" class="btn btn--primary">教材を探す →</a>
      <a href="/about" class="btn btn--ghost">サイトについて</a>
    </div>
  </section>

  {/* 今日の一篇 (クライアントサイドで日付ハッシュ → 1 件選出) */}
  <section class="section daily-pick-section no-print" data-daily-pick-root data-daily-candidates={JSON.stringify(dailyCandidates)}>
    <div class="section__heading">
      <h2>今日の一篇</h2>
      <span class="section__subtitle">DAILY PICK</span>
    </div>
    <div class="daily-pick" data-daily-pick>
      <p style="color: var(--text-soft);">読み込み中…</p>
    </div>
  </section>

  {/* 続きから読むウィジェット（クライアントサイドで localStorage を読んで表示） */}
  <section class="section no-print" data-resume-widget-root hidden>
    <aside class="resume-widget" aria-labelledby="resume-widget-title">
      <div class="resume-widget__header">
        <h2 class="resume-widget__title" id="resume-widget-title">続きから読む</h2>
        <button type="button" class="resume-widget__clear" data-resume-widget-clear aria-label="ブックマークをすべて消去">すべて消去</button>
      </div>
      <ul class="resume-widget__list" data-resume-widget-list></ul>
    </aside>
  </section>

  <section class="section">
    <div class="section__heading">
      <h2>新しい教材</h2>
      <span class="section__subtitle">FEATURED</span>
    </div>

    {featured.length === 0 ? (
      <div class="empty-state">
        <h3>準備中です</h3>
        <p>最初の教材を編集中。<br />しばらくお待ちください。</p>
      </div>
    ) : (
      <div class="lesson-grid">
        {featured.map((lesson) => {
          const stagePrefix = lesson.data.school_stage === 'kotoko'
            ? '高'
            : lesson.data.school_stage === 'chugaku'
              ? '中'
              : '小';
          return (
            <article class="lesson-card">
              <a href={`/library/${lesson.collection}/${lesson.id}`} class="lesson-card__link">
                <p class="lesson-card__meta">
                  {stagePrefix}{lesson.data.grade} ・ {lesson.data.subject}
                  {lesson.data.classical && ' ・ 古典'}
                </p>
                <h3 class="lesson-card__title">{lesson.data.title}</h3>
                <p class="lesson-card__desc">{lesson.data.description}</p>
                <p class="lesson-card__author">
                  {lesson.data.author}
                  {lesson.data.era ? `（${lesson.data.era}）` : lesson.data.original_year ? `（${lesson.data.original_year}）` : ''}
                </p>
              </a>
            </article>
          );
        })}
      </div>
    )}
  </section>

  <script is:inline>
    // ─── 今日の一篇 ───
    (function () {
      const root = document.querySelector('[data-daily-pick-root]');
      const target = document.querySelector('[data-daily-pick]');
      if (!root || !target) return;
      let candidates = [];
      try { candidates = JSON.parse(root.dataset.dailyCandidates || '[]'); } catch (_) {}
      if (!candidates.length) { target.innerHTML = ''; return; }

      // 利用者のローカル日付を seed にハッシュ
      const today = new Date();
      const key = today.getFullYear() + '-' + (today.getMonth() + 1) + '-' + today.getDate();
      let h = 0;
      for (let i = 0; i < key.length; i++) h = (h * 31 + key.charCodeAt(i)) >>> 0;
      const idx = h % candidates.length;
      const pick = candidates[idx];
      const yearText = pick.year ? '（' + pick.year + '年）' : pick.era ? '（' + pick.era + '）' : '';

      function escapeHtml(s) {
        if (s == null) return '';
        return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      }
      target.innerHTML =
        '<article class="daily-pick__card">' +
          '<a href="' + escapeHtml(pick.path) + '" class="daily-pick__link">' +
            '<p class="daily-pick__date">' + key + ' のおすすめ</p>' +
            '<h3 class="daily-pick__title">' + escapeHtml(pick.title) + '</h3>' +
            '<p class="daily-pick__author">' + escapeHtml(pick.author) + escapeHtml(yearText) + '</p>' +
            '<p class="daily-pick__desc">' + escapeHtml(pick.description) + '</p>' +
            '<p class="daily-pick__cta">この教材を開く →</p>' +
          '</a>' +
        '</article>';
    })();
  </script>

  <script is:inline>
    // ─── 「続きから読む」ウィジェット ───
    (function () {
      const root = document.querySelector('[data-resume-widget-root]');
      if (!root) return;
      const list = root.querySelector('[data-resume-widget-list]');
      const clearBtn = root.querySelector('[data-resume-widget-clear]');
      const STORAGE_KEY = 'hiraku.bookmarks.v1';

      function readBookmarks() {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          if (!raw) return { lessons: {} };
          const parsed = JSON.parse(raw);
          if (!parsed || !parsed.lessons) return { lessons: {} };
          return parsed;
        } catch (_) { return { lessons: {} }; }
      }

      function render() {
        const data = readBookmarks();
        const items = Object.values(data.lessons || {})
          .filter((b) => b && b.path && b.title)
          .sort((a, b) => (b.ts || 0) - (a.ts || 0))
          .slice(0, 4);

        if (items.length === 0) {
          root.hidden = true;
          return;
        }
        root.hidden = false;
        list.innerHTML = '';
        for (const b of items) {
          const li = document.createElement('li');
          li.className = 'resume-widget__item';
          const pct = Math.round((b.progress || 0) * 100);
          const author = b.author ? ' ・ ' + b.author : '';
          const a = document.createElement('a');
          a.href = b.path;
          a.innerHTML =
            '<span class="resume-widget__item-progress" aria-hidden="true">' +
              '<span class="resume-widget__item-bar" style="width:' + pct + '%"></span>' +
            '</span>' +
            '<span class="resume-widget__item-body">' +
              '<span class="resume-widget__item-title">' + escapeHtml(b.title) + '</span>' +
              '<span class="resume-widget__item-meta">' + escapeHtml(author) + '</span>' +
            '</span>' +
            '<span class="resume-widget__item-pct">' + pct + '%</span>';
          li.appendChild(a);
          list.appendChild(li);
        }
      }

      function escapeHtml(s) {
        if (s == null) return '';
        return String(s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      if (clearBtn) {
        clearBtn.addEventListener('click', () => {
          if (!confirm('保存されたすべてのブックマークを消去しますか？')) return;
          try { localStorage.removeItem(STORAGE_KEY); } catch (_) {}
          render();
        });
      }

      render();
      // 他タブで更新された場合の同期
      window.addEventListener('storage', (e) => {
        if (e.key === STORAGE_KEY) render();
      });
    })();
  </script>

  <section class="section">
    <div class="section__heading">
      <h2>このプロジェクトについて</h2>
      <span class="section__subtitle">ABOUT</span>
    </div>
    <p>
      <strong>ひらく</strong>（project_procopios）は、著作権が満了したパブリックドメインの
      近代日本の読み物を、現代の学習指導要領に沿って編集し、無償・オープンライセンスで
      公開するプロジェクトです。
    </p>
    <p>
      明治・大正・昭和初期の日本語表記をそのまま現代の児童が読むのは難しいことがあります。
      現代仮名遣いへの修正、ふりがな（ルビ）の付与、語注、発問、
      そして現行指導要領との対応関係を明示することで、教室・家庭・自学のいずれでも
      すぐに使える教材を整えていきます。
    </p>
    <div class="callout">
      <strong>ご注意：</strong> 本サイトは文部科学省検定済教科書ではありません。
      <strong>自主教材（副教材）</strong>としてご活用ください。
    </div>
  </section>
</Base>
