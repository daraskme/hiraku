---
import Logo from './Logo.astro';

const path = Astro.url.pathname;
function isActive(href: string) {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href + '/');
}

const navItems = [
  { href: '/', label: 'ホーム', icon: '⌂' },
  { href: '/library', label: 'ライブラリ', icon: '📖' },
  { href: '/reader', label: 'リーダー', icon: '✦' },
  { href: '/progress', label: '進捗', icon: '◐' },
  { href: '/community', label: '対話', icon: '◌' },
];

const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || '';
const authEnabled = !!googleClientId;
---

<header class="site-header">
  <div class="site-header__inner">
    <Logo />

    <nav class="nav" aria-label="主要ナビゲーション">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="nav__link"
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          <span class="nav__icon" aria-hidden="true">{item.icon}</span>
          <span class="nav__label">{item.label}</span>
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <a
        href="/search"
        class="icon-btn"
        aria-label="検索"
        title="検索"
      >
        <span aria-hidden="true">⌕</span>
      </a>

      {authEnabled && (
        <div
          id="g_id_onload"
          data-client_id={googleClientId}
          data-callback="handleGoogleCredentialResponse"
          data-auto_prompt="false"
          data-context="signin"
        ></div>
      )}

      {authEnabled && (
        <div class="user-toggle" data-user-toggle-root>
          <button
            type="button"
            class="icon-btn user-toggle__btn"
            aria-label="アカウント"
            aria-expanded="false"
            data-user-toggle
            title="アカウント"
          >
            <span class="user-toggle__icon-default" aria-hidden="true">○</span>
            <img
              class="user-toggle__avatar"
              src=""
              alt=""
              data-user-avatar
              hidden
            />
          </button>
          <div class="user-panel" data-user-panel role="dialog" aria-label="アカウント">
            {/* 未ログイン時 */}
            <div class="user-panel__signed-out" data-user-signed-out>
              <h3>クラウド同期</h3>
              <p class="user-panel__note">
                Google でログインすると、進捗・ブックマーク・英単語履歴・表示設定が
                すべての端末で同期されます。<br />
                ログインしなくても、すべての機能が端末内でそのまま使えます。
              </p>
              {/* GIS が自動でボタンをレンダーする */}
              <div
                id="g_id_signin"
                data-type="standard"
                data-shape="rectangular"
                data-theme="outline"
                data-text="signin_with"
                data-size="large"
                data-locale="ja"
              ></div>
              <div class="user-panel__fallback" data-user-fallback hidden>
                <button type="button" class="user-panel__retry" data-user-retry>
                  ログインボタンを再読み込み
                </button>
              </div>
            </div>

            {/* ログイン中 */}
            <div class="user-panel__signed-in" data-user-signed-in hidden>
              <div class="user-panel__identity">
                <img class="user-panel__avatar" src="" alt="" data-user-panel-avatar />
                <div>
                  <div class="user-panel__name" data-user-name></div>
                  <div class="user-panel__email" data-user-email></div>
                </div>
              </div>
              <div class="user-panel__sync-status" data-user-sync-status aria-live="polite">
                同期済み
              </div>
              <button type="button" class="user-panel__signout" data-user-signout>
                ログアウト
              </button>
              <details class="user-panel__danger">
                <summary>クラウドデータの管理…</summary>
                <button
                  type="button"
                  class="user-panel__delete-cloud"
                  data-user-delete-cloud
                >
                  クラウドの学習データを削除
                </button>
                <p class="user-panel__danger-note">
                  サーバ上の進捗・ブックマーク・履歴・設定を完全に削除します。
                  この端末のデータは残ります。元に戻せません。
                </p>
              </details>
            </div>
          </div>
        </div>
      )}
      <div class="a11y-toggle">
        <button
          type="button"
          class="icon-btn"
          aria-label="表示設定"
          aria-expanded="false"
          data-a11y-toggle
        >
          <span aria-hidden="true">Aa</span>
        </button>
        <div class="a11y-panel" data-a11y-panel role="dialog" aria-label="表示設定">
          <h3>表示設定</h3>

          <div class="a11y-row">
            <span class="a11y-row__label">テーマ</span>
            <div class="a11y-row__controls" role="group" aria-label="カラーテーマ">
              <button type="button" class="a11y-btn" data-theme-set="light" aria-label="ライトモード">☀</button>
              <button type="button" class="a11y-btn" data-theme-set="dark" aria-label="ダークモード">☾</button>
              <button type="button" class="a11y-btn" data-theme-set="auto" aria-label="システムに合わせる">auto</button>
            </div>
          </div>

          <div class="a11y-row">
            <span class="a11y-row__label">文字サイズ</span>
            <div class="a11y-row__controls" role="group" aria-label="文字サイズ">
              <button type="button" class="a11y-btn" data-fs-set="0.9" aria-label="小">A-</button>
              <button type="button" class="a11y-btn" data-fs-set="1" aria-label="標準">A</button>
              <button type="button" class="a11y-btn" data-fs-set="1.15" aria-label="大">A+</button>
              <button type="button" class="a11y-btn" data-fs-set="1.3" aria-label="特大">A++</button>
            </div>
          </div>

          <div class="a11y-row">
            <span class="a11y-row__label">ふりがな</span>
            <div class="a11y-row__controls" role="group" aria-label="ふりがな">
              <button type="button" class="a11y-btn" data-ruby-set="on" aria-label="表示">表示</button>
              <button type="button" class="a11y-btn" data-ruby-set="off" aria-label="非表示">非表示</button>
            </div>
          </div>

          <div class="a11y-row">
            <span class="a11y-row__label">高コントラスト</span>
            <div class="a11y-row__controls" role="group" aria-label="高コントラスト">
              <button type="button" class="a11y-btn" data-contrast-set="normal" aria-label="標準">標準</button>
              <button type="button" class="a11y-btn" data-contrast-set="high" aria-label="高">高</button>
            </div>
          </div>

          <div class="a11y-row">
            <span class="a11y-row__label">縦書き</span>
            <div class="a11y-row__controls" role="group" aria-label="縦書き">
              <button type="button" class="a11y-btn" data-writing-set="horizontal" aria-label="横書き">横</button>
              <button type="button" class="a11y-btn" data-writing-set="vertical" aria-label="縦書き">縦</button>
            </div>
          </div>
        </div>
      </div>

      <button
        type="button"
        class="icon-btn hamburger"
        aria-label="メニュー"
        aria-expanded="false"
        data-mobile-toggle
      >
        <span aria-hidden="true">☰</span>
      </button>
    </div>
  </div>

  <div class="mobile-menu" data-mobile-menu aria-label="モバイルメニュー">
    <ul class="mobile-menu__list">
      {navItems.map((item) => (
        <li class="mobile-menu__item">
          <a
            href={item.href}
            class="mobile-menu__link"
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            <span class="mobile-menu__icon" aria-hidden="true">{item.icon}</span>
            <span>{item.label}</span>
          </a>
        </li>
      ))}
      <li class="mobile-menu__item">
        <a href="/authors" class="mobile-menu__link">
          <span class="mobile-menu__icon" aria-hidden="true">✎</span>
          <span>著者一覧</span>
        </a>
      </li>
      <li class="mobile-menu__item">
        <a href="/eras" class="mobile-menu__link">
          <span class="mobile-menu__icon" aria-hidden="true">⌛</span>
          <span>時代別アーカイブ</span>
        </a>
      </li>
      <li class="mobile-menu__item">
        <a href="/timeline" class="mobile-menu__link">
          <span class="mobile-menu__icon" aria-hidden="true">⌖</span>
          <span>時代年表</span>
        </a>
      </li>
      <li class="mobile-menu__item">
        <a href="/curriculum" class="mobile-menu__link">
          <span class="mobile-menu__icon" aria-hidden="true">▤</span>
          <span>学習指導要領インデックス</span>
        </a>
      </li>
      <li class="mobile-menu__item">
        <a href="/about" class="mobile-menu__link">
          <span class="mobile-menu__icon" aria-hidden="true">ⓘ</span>
          <span>このサイトについて</span>
        </a>
      </li>
      <li class="mobile-menu__item">
        <a href="/license" class="mobile-menu__link">
          <span class="mobile-menu__icon" aria-hidden="true">©</span>
          <span>ライセンス</span>
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // A11y パネル
  const a11yToggle = document.querySelector<HTMLButtonElement>('[data-a11y-toggle]');
  const a11yPanel = document.querySelector<HTMLElement>('[data-a11y-panel]');
  a11yToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = a11yPanel?.classList.toggle('is-open');
    a11yToggle.setAttribute('aria-expanded', String(open));
  });
  document.addEventListener('click', (e) => {
    if (a11yPanel && !a11yPanel.contains(e.target as Node) && e.target !== a11yToggle) {
      a11yPanel.classList.remove('is-open');
      a11yToggle?.setAttribute('aria-expanded', 'false');
    }
  });

  // モバイルメニュー
  const mobileToggle = document.querySelector<HTMLButtonElement>('[data-mobile-toggle]');
  const mobileMenu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  mobileToggle?.addEventListener('click', () => {
    const open = mobileMenu?.classList.toggle('is-open');
    mobileToggle.setAttribute('aria-expanded', String(open));
  });

  // ----- 設定の保存と復元 -----
  const root = document.documentElement;
  const ls = window.localStorage;

  function applyTheme(v: string) {
    if (v === 'auto') root.removeAttribute('data-theme');
    else root.setAttribute('data-theme', v);
    document.querySelectorAll<HTMLButtonElement>('[data-theme-set]').forEach((b) => {
      b.setAttribute('aria-pressed', String(b.dataset.themeSet === v));
    });
  }
  function applyFontSize(v: string) {
    root.style.setProperty('--font-size-scale', v);
    document.querySelectorAll<HTMLButtonElement>('[data-fs-set]').forEach((b) => {
      b.setAttribute('aria-pressed', String(b.dataset.fsSet === v));
    });
  }
  function applyRuby(v: string) {
    if (v === 'on') root.removeAttribute('data-ruby');
    else root.setAttribute('data-ruby', v);
    document.querySelectorAll<HTMLButtonElement>('[data-ruby-set]').forEach((b) => {
      b.setAttribute('aria-pressed', String(b.dataset.rubySet === v));
    });
  }
  function applyContrast(v: string) {
    if (v === 'normal') root.removeAttribute('data-contrast');
    else root.setAttribute('data-contrast', v);
    document.querySelectorAll<HTMLButtonElement>('[data-contrast-set]').forEach((b) => {
      b.setAttribute('aria-pressed', String(b.dataset.contrastSet === v));
    });
  }
  function applyWriting(v: string) {
    if (v === 'horizontal') root.removeAttribute('data-writing');
    else root.setAttribute('data-writing', v);
    document.querySelectorAll<HTMLButtonElement>('[data-writing-set]').forEach((b) => {
      b.setAttribute('aria-pressed', String(b.dataset.writingSet === v));
    });
  }

  // 初期値復元（明示的に切り替えない限り常にライト）
  applyTheme(ls.getItem('theme') || 'light');
  applyFontSize(ls.getItem('fontSize') || '1');
  applyRuby(ls.getItem('ruby') || 'on');
  applyContrast(ls.getItem('contrast') || 'normal');
  applyWriting(ls.getItem('writing') || 'horizontal');

  // ローカル変更を HirakuAuth (auth.js) に伝えてクラウド同期をスケジュール
  function notifySync() {
    const w = window as any;
    if (w.HirakuAuth && typeof w.HirakuAuth.scheduleSync === 'function') {
      w.HirakuAuth.scheduleSync();
    }
  }

  document.querySelectorAll<HTMLButtonElement>('[data-theme-set]').forEach((b) => {
    b.addEventListener('click', () => {
      const v = b.dataset.themeSet!;
      ls.setItem('theme', v);
      applyTheme(v);
      notifySync();
    });
  });
  document.querySelectorAll<HTMLButtonElement>('[data-fs-set]').forEach((b) => {
    b.addEventListener('click', () => {
      const v = b.dataset.fsSet!;
      ls.setItem('fontSize', v);
      applyFontSize(v);
      notifySync();
    });
  });
  document.querySelectorAll<HTMLButtonElement>('[data-ruby-set]').forEach((b) => {
    b.addEventListener('click', () => {
      const v = b.dataset.rubySet!;
      ls.setItem('ruby', v);
      applyRuby(v);
      notifySync();
    });
  });
  document.querySelectorAll<HTMLButtonElement>('[data-contrast-set]').forEach((b) => {
    b.addEventListener('click', () => {
      const v = b.dataset.contrastSet!;
      ls.setItem('contrast', v);
      applyContrast(v);
      notifySync();
    });
  });
  document.querySelectorAll<HTMLButtonElement>('[data-writing-set]').forEach((b) => {
    b.addEventListener('click', () => {
      const v = b.dataset.writingSet!;
      ls.setItem('writing', v);
      applyWriting(v);
      notifySync();
    });
  });

  // ─── ユーザーパネル：トグルとログイン/ログアウト UI ───
  const userToggle = document.querySelector<HTMLButtonElement>('[data-user-toggle]');
  const userPanel = document.querySelector<HTMLElement>('[data-user-panel]');
  if (userToggle && userPanel) {
    // GSI のサインインボタンは display:none の親要素では自動描画されないため、
    // パネルを開いたタイミングで明示的に renderButton を呼ぶ。
    // GSI スクリプトの非同期読み込みに備えて、未到達ならポーリングでリトライ。
    let gsiRenderAttempts = 0;
    function ensureGoogleButtonRendered() {
      const target = document.getElementById('g_id_signin');
      const fallback = userPanel!.querySelector<HTMLElement>('[data-user-fallback]');
      if (!target) return;
      // 既に描画済み (GSI は内部に iframe/div を挿入する) ならスキップ
      if (target.querySelector('div, iframe')) {
        if (fallback) fallback.hidden = true;
        return;
      }
      const gid = (window as any).google?.accounts?.id;
      if (gid && typeof gid.renderButton === 'function') {
        try {
          gid.renderButton(target, {
            type: 'standard',
            shape: 'rectangular',
            theme: 'outline',
            text: 'signin_with',
            size: 'large',
            locale: 'ja',
          });
          if (fallback) fallback.hidden = true;
        } catch (_) {
          if (fallback) fallback.hidden = false;
        }
        return;
      }
      // GSI スクリプト未到達。最大 4 秒間ポーリング
      if (gsiRenderAttempts < 20) {
        gsiRenderAttempts++;
        window.setTimeout(ensureGoogleButtonRendered, 200);
      } else if (fallback) {
        // 諦めて再読み込みボタンを表示
        fallback.hidden = false;
      }
    }

    userToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = userPanel.classList.toggle('is-open');
      userToggle.setAttribute('aria-expanded', String(open));
      if (open) ensureGoogleButtonRendered();
    });
    document.addEventListener('click', (e) => {
      if (!userPanel.contains(e.target as Node) && e.target !== userToggle) {
        userPanel.classList.remove('is-open');
        userToggle.setAttribute('aria-expanded', 'false');
      }
    });

    // Google Identity Services のコールバック：window 直下に登録される必要がある
    (window as any).handleGoogleCredentialResponse = async (resp: { credential?: string }) => {
      const w = window as any;
      if (!resp || !resp.credential || !w.HirakuAuth) return;
      try {
        await w.HirakuAuth.handleGoogleCredential(resp.credential);
      } catch (err) {
        const status = userPanel.querySelector<HTMLElement>('[data-user-sync-status]');
        if (status) status.textContent = 'ログインに失敗しました';
      }
    };

    // 認証状態変化を UI に反映
    const signedOut = userPanel.querySelector<HTMLElement>('[data-user-signed-out]');
    const signedIn = userPanel.querySelector<HTMLElement>('[data-user-signed-in]');
    const avatar = document.querySelector<HTMLImageElement>('[data-user-avatar]');
    const panelAvatar = userPanel.querySelector<HTMLImageElement>('[data-user-panel-avatar]');
    const nameEl = userPanel.querySelector<HTMLElement>('[data-user-name]');
    const emailEl = userPanel.querySelector<HTMLElement>('[data-user-email]');
    const iconDefault = userToggle.querySelector<HTMLElement>('.user-toggle__icon-default');

    function applyAuthState(user: any) {
      const isIn = !!user;
      if (signedOut) signedOut.hidden = isIn;
      if (signedIn) signedIn.hidden = !isIn;
      if (avatar && iconDefault) {
        if (isIn && user.picture) {
          avatar.src = user.picture;
          avatar.alt = user.name || 'ユーザー';
          avatar.hidden = false;
          iconDefault.style.display = 'none';
        } else {
          avatar.hidden = true;
          avatar.removeAttribute('src');
          iconDefault.style.display = '';
        }
      }
      if (panelAvatar && isIn && user.picture) {
        panelAvatar.src = user.picture;
        panelAvatar.alt = user.name || 'ユーザー';
      }
      if (nameEl) nameEl.textContent = isIn ? (user.name || '匿名ユーザー') : '';
      if (emailEl) emailEl.textContent = isIn ? (user.email || '') : '';
    }

    // 起動時にキャッシュからユーザーを描画
    const w = window as any;
    if (w.HirakuAuth) applyAuthState(w.HirakuAuth.getUser());
    window.addEventListener('hiraku:auth', (e: any) => {
      applyAuthState(e.detail && e.detail.user);
    });

    // 同期ステータス表示
    const syncStatus = userPanel.querySelector<HTMLElement>('[data-user-sync-status]');
    let syncTimer: number | null = null;
    function setSyncStatus(text: string, classMod: string = '') {
      if (!syncStatus) return;
      syncStatus.textContent = text;
      syncStatus.classList.remove('user-panel__sync-status--ok', 'user-panel__sync-status--err', 'user-panel__sync-status--offline');
      if (classMod) syncStatus.classList.add(classMod);
    }
    window.addEventListener('hiraku:sync', (e: any) => {
      if (!syncStatus) return;
      const d = e.detail || {};
      if (d.deleted) {
        setSyncStatus('クラウドのデータを削除しました', 'user-panel__sync-status--ok');
      } else if (d.offline || (typeof navigator !== 'undefined' && navigator.onLine === false)) {
        setSyncStatus('オフライン — 復帰時に同期します', 'user-panel__sync-status--offline');
      } else if (d.ok) {
        setSyncStatus('同期しました', 'user-panel__sync-status--ok');
      } else {
        setSyncStatus('同期に失敗しました — 次の変更時に再試行', 'user-panel__sync-status--err');
      }
      if (syncTimer) window.clearTimeout(syncTimer);
      syncTimer = window.setTimeout(() => {
        setSyncStatus(navigator.onLine === false ? 'オフライン' : '同期済み');
        syncTimer = null;
      }, 4000);
    });
    // 起動時にオフラインなら初期表示
    if (typeof navigator !== 'undefined' && navigator.onLine === false) {
      setSyncStatus('オフライン', 'user-panel__sync-status--offline');
    }

    // ログアウト
    const signOutBtn = userPanel.querySelector<HTMLButtonElement>('[data-user-signout]');
    signOutBtn?.addEventListener('click', async () => {
      const w = window as any;
      if (w.HirakuAuth) await w.HirakuAuth.signOut();
    });

    // クラウドデータ削除
    const deleteCloudBtn = userPanel.querySelector<HTMLButtonElement>('[data-user-delete-cloud]');
    deleteCloudBtn?.addEventListener('click', async () => {
      if (!confirm('サーバ上の進捗・ブックマーク・履歴・設定をすべて削除します。\nこの端末のデータは残ります。\n\n本当に削除しますか？')) return;
      const w = window as any;
      if (w.HirakuAuth && typeof w.HirakuAuth.deleteCloudData === 'function') {
        try {
          await w.HirakuAuth.deleteCloudData();
          if (syncStatus) syncStatus.textContent = 'クラウドのデータを削除しました';
        } catch (err) {
          if (syncStatus) syncStatus.textContent = '削除に失敗しました';
        }
      }
    });

    // ボタンが出ない場合の再読み込み (GIS スクリプトの後追い登録が必要なケース)
    const retryBtn = userPanel.querySelector<HTMLButtonElement>('[data-user-retry]');
    retryBtn?.addEventListener('click', () => {
      const target = document.getElementById('g_id_signin');
      if (target) target.innerHTML = '';
      gsiRenderAttempts = 0;
      ensureGoogleButtonRendered();
    });
  }
</script>
