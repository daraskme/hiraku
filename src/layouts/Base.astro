---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
  ogImage?: string;
  lang?: 'ja' | 'en';
  hrefAlt?: string; // 翻訳版へのリンク URL（hreflang alternate 用）
}

const { title, description, wide = false, ogImage, lang = 'ja', hrefAlt } = Astro.props;
const siteName = lang === 'en' ? 'Hiraku' : 'ひらく';
const fullTitle = title === siteName ? siteName : `${title} | ${siteName}`;
const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || '';
const containerClass = wide ? 'container container--wide' : 'container';

// 教材ページの URL パターンを検知して OG 画像を自動選択
// WebP を主、PNG をフォールバック（古いクライアント互換）として出力
const path = Astro.url.pathname;
const lessonMatch = path.match(/^\/(?:library|reader)\/([^/]+)\/([^/]+)\/?$/);
const computedOgImage = ogImage
  || (lessonMatch ? `/og/${lessonMatch[1]}/${lessonMatch[2]}.webp` : '/og/default.webp');
const computedOgImagePng = ogImage
  || (lessonMatch ? `/og/${lessonMatch[1]}/${lessonMatch[2]}.png` : '/og/default.png');
const siteUrl = Astro.site || new URL('https://hiraku-5cb.pages.dev/');
const ogImageUrl = new URL(computedOgImage, siteUrl).toString();
const ogImagePngUrl = new URL(computedOgImagePng, siteUrl).toString();
const ogImageType = ogImage ? (ogImage.endsWith('.png') ? 'image/png' : ogImage.endsWith('.jpg') || ogImage.endsWith('.jpeg') ? 'image/jpeg' : 'image/webp') : 'image/webp';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageAlt = title === siteName
  ? (lang === 'en'
      ? 'Hiraku — an open-source educational project re-editing public-domain Japanese textbook materials per the current Course of Study (MEXT, 2017–2018 revision).'
      : 'ひらく — 著作権切れの教科書を、現行学習指導要領（平成29年告示）に沿って再編集して公開するオープン教材プロジェクト')
  : (lang === 'en'
      ? `${title} — Hiraku`
      : `${title} — ひらく（教材）`);
const ogLocale = lang === 'en' ? 'en_US' : 'ja_JP';
const ogLocaleAlt = lang === 'en' ? 'ja_JP' : 'en_US';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />
    {hrefAlt && (
      <link rel="alternate" hreflang={lang === 'en' ? 'ja' : 'en'} href={new URL(hrefAlt, siteUrl).toString()} />
    )}
    {hrefAlt && (
      <link rel="alternate" hreflang="x-default" href={new URL(lang === 'en' ? hrefAlt : Astro.url.pathname, siteUrl).toString()} />
    )}

    {/* ─── Open Graph (Facebook, LINE, Slack, Discord, Telegram, etc.) ─── */}
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={ogLocale} />
    {hrefAlt && <meta property="og:locale:alternate" content={ogLocaleAlt} />}
    {/* WebP を主に。互換性のため PNG も併記。og:image を複数出すと最初に処理可能なものが選ばれる */}
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    {ogImageUrl !== ogImagePngUrl && (
      <>
        <meta property="og:image" content={ogImagePngUrl} />
        <meta property="og:image:type" content="image/png" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={ogImageAlt} />
      </>
    )}

    {/* ─── Twitter / X Cards ─── */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="ひらく — 新着教材" href="/feed.xml" />
    <meta name="theme-color" content="#1d2a3d" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f3efe5" media="(prefers-color-scheme: light)" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="ひらく" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@500;700&display=swap"
    />
  </head>
  <body>
    <a href="#main" class="skip-link">{lang === 'en' ? 'Skip to main content' : '本文へスキップ'}</a>
    <Header />
    <main id="main" class={containerClass} tabindex="-1">
      <slot />
    </main>
    <BottomNav />
    <Footer />
    <script src="/auth.js" is:inline></script>
    <script src="/badges.js" is:inline></script>
    <script src="/progress.js" is:inline></script>
    <script src="/error-reporter.js" is:inline></script>
    {googleClientId && (
      <script src="https://accounts.google.com/gsi/client" async defer is:inline></script>
    )}
    <script is:inline>
      // Service Worker 登録（PWA / オフライン対応）
      if ('serviceWorker' in navigator && location.protocol === 'https:') {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js', { scope: '/' }).catch(() => {
            /* ignore registration failure */
          });
        });
      }
    </script>
  </body>
</html>
