---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

interface Props {
  lesson:
    | CollectionEntry<'kokugo3'>
    | CollectionEntry<'kokugo4'>
    | CollectionEntry<'kokugo6'>
    | CollectionEntry<'chugaku1'>
    | CollectionEntry<'chugaku2'>
    | CollectionEntry<'chugaku3'>
    | CollectionEntry<'kotoko1'>
    | CollectionEntry<'kotoko2'>
    | CollectionEntry<'kateika5'>
    | CollectionEntry<'chugakurika1'>
    | CollectionEntry<'chugakurekishi1'>
    | CollectionEntry<'kotorekishi1'>
    | CollectionEntry<'kotosekaishi1'>
    | CollectionEntry<'kotokoeigo1'>
    | CollectionEntry<'sansu5'>
    | CollectionEntry<'chugakukomin3'>;
}

const { lesson } = Astro.props;
const d = lesson.data;

// ─── 関連教材の計算 ────────────────────────────────
const COLLECTION_NAMES = [
  'kokugo3',
  'kokugo4',
  'kokugo6',
  'chugaku1',
  'chugaku2',
  'chugaku3',
  'kotoko1',
  'kotoko2',
  'kateika5',
  'chugakurika1',
  'chugakurekishi1',
  'kotokoeigo1',
  'sansu5',
  'chugakukomin3',
  'kotorekishi1',
  'kotosekaishi1',
] as const;
const COLLECTION_LABEL: Record<string, string> = {
  kokugo3: '小3 国語',
  kokugo4: '小4 国語',
  kokugo6: '小6 国語',
  chugaku1: '中1 国語',
  chugaku2: '中2 国語',
  chugaku3: '中3 国語',
  kotoko1: '高1 国語',
  kotoko2: '高2 国語',
  kateika5: '小5 家庭科',
  chugakurika1: '中1 理科',
  chugakurekishi1: '中1 歴史',
  kotokoeigo1: '高1 英語',
  sansu5: '小5 算数',
  chugakukomin3: '中3 公民',
  kotorekishi1: '高1 日本史',
  kotosekaishi1: '高1 世界史',
};

const allLessons: any[] = [];
for (const name of COLLECTION_NAMES) {
  const items = await getCollection(name as any);
  for (const l of items as any[]) allLessons.push({ collection: name, lesson: l });
}

interface RelatedScore {
  collection: string;
  lesson: any;
  score: number;
  reason: string;
}
const lessonKeywords = new Set<string>(d.keywords || []);
const related: RelatedScore[] = [];
for (const entry of allLessons) {
  if (entry.collection === lesson.collection && entry.lesson.id === lesson.id) continue;
  let score = 0;
  let reason = '';
  // Same author = strong
  if (entry.lesson.data.author === d.author) {
    score += 10;
    reason = '同じ作者';
  }
  // Keyword overlap
  const otherKeywords = new Set<string>(entry.lesson.data.keywords || []);
  let overlap = 0;
  for (const k of lessonKeywords) if (otherKeywords.has(k)) overlap++;
  if (overlap > 0) {
    score += overlap * 3;
    if (!reason) reason = `共通テーマ：${[...lessonKeywords].filter((k) => otherKeywords.has(k)).slice(0, 2).join('・')}`;
  }
  // Same collection (school stage + subject)
  if (entry.collection === lesson.collection) {
    score += 2;
    if (!reason) reason = COLLECTION_LABEL[entry.collection] + ' の別教材';
  }
  // Classical kinship
  if (d.classical && entry.lesson.data.classical) {
    score += 3;
    if (!reason) reason = '同じ古典作品の系列';
  }
  if (score >= 3) related.push({ collection: entry.collection, lesson: entry.lesson, score, reason });
}
related.sort((a, b) => b.score - a.score);
const relatedTop = related.slice(0, 4);

const stageLabel: Record<string, string> = {
  shogaku: '小学校',
  chugaku: '中学校',
  kotoko: '高等学校',
};
const stage = stageLabel[d.school_stage] ?? '小学校';
const guidelineDoc = d.school_stage === 'kotoko'
  ? '高等学校学習指導要領（平成30年告示）'
  : d.school_stage === 'chugaku'
    ? '中学校学習指導要領（平成29年告示）'
    : '小学校学習指導要領（平成29年告示）';
---

<Base title={d.title} description={d.description}>
  {/*
    Pagefind は日本語の場合、単語境界（スペース）を自動推定できないため、
    検索ヒット率を上げるための「補助キーワード」を非表示で埋め込む。
    キーワード・glossary の term・作者の読み（author_dates の年と並列の人名情報）を
    全角スペース区切りで列挙することで、ひらがな・カタカナ・漢字どの入力でも
    Pagefind が部分一致しやすくなる。
  */}
  <article
    data-pagefind-filter={`段階:${stage}, 教科:${d.subject}, 学年:${stage} 第${d.grade}学年${d.classical ? ', 種別:古典' : ''}`}
    data-pagefind-meta={`作者:${d.author}, 段階:${stage}`}
    data-lesson-subject={d.subject}
    data-lesson-collection={lesson.collection}
    data-lesson-id={lesson.id}
    data-lesson-title={d.title}
    data-lesson-author={d.author}
  >
    <div class="pagefind-aux" data-pagefind-body aria-hidden="true" style="position: absolute; left: -10000px; top: auto; width: 1px; height: 1px; overflow: hidden;">
      {/* 検索補助：keywords / glossary の term を非表示で展開 */}
      <span>{d.title}</span>
      <span>{d.author}</span>
      {d.keywords.map((k) => <span> {k}</span>)}
      {d.glossary.map((g) => <span> {g.term}</span>)}
      {/* ひらがな・カタカナ正規化のヒントとして、よくある検索語の組み合わせ */}
      {d.classical && <span>古典 こてん コテン</span>}
    </div>
    <header class="lesson-header">
      <div class="lesson-header__top no-print">
        <a href="/library" class="lesson-header__back">← ライブラリへ戻る</a>
        <div class="lesson-header__actions">
          <a href={`/reader/${lesson.collection}/${lesson.id}`} class="lesson-header__action-link" title="フルスクリーンで読む">
            ✦ リーダーモードで読む
          </a>
          {d.questions && d.questions.length > 0 && (
            <a href={`/quiz/${lesson.collection}/${lesson.id}`} class="lesson-header__action-link lesson-header__action-link--accent" title="問いを1問ずつ考える">
              ? クイズで考える
            </a>
          )}
          {d.glossary && d.glossary.length > 0 && (
            <a href={`/flashcards/${lesson.collection}/${lesson.id}`} class="lesson-header__action-link" title="語句をフラッシュカードで覚える">
              ▣ 単語カード
            </a>
          )}
          <a href={`/worksheet/${lesson.collection}/${lesson.id}`} class="lesson-header__action-link" title="A4 印刷用のワークシート">
            ⎙ ワークシート印刷
          </a>
        </div>
      </div>
      {d.cover_image && (
        <figure class="lesson-cover">
          <img src={d.cover_image} alt={`${d.title} の表紙イラスト`} loading="eager" />
        </figure>
      )}
      <h1 class="lesson-header__title">{d.title}</h1>
      <p class="lesson-header__badges">
        <span class="badge">{stage} {d.subject} 第{d.grade}学年</span>
        {d.classical && <span class="badge badge--accent">古典</span>}
        {d.domains.map((dom) => <span class="badge">{dom}</span>)}
        {d.estimated_minutes && <span class="badge">目安 {d.estimated_minutes} 分</span>}
      </p>

      <section class="meta-panel" aria-label="教材メタ情報">
        <dl>
          <dt>作者</dt>
          <dd>
            <a href={`/authors/${encodeURIComponent(d.author)}`} style="color: inherit; text-decoration: underline; text-decoration-style: dotted; text-underline-offset: 3px;">{d.author}</a>{d.author_dates ? `（${d.author_dates}）` : ''}
          </dd>
          {d.original_year && (
            <>
              <dt>原作発表</dt>
              <dd>{d.original_year} 年{d.era ? `（${d.era}）` : ''}</dd>
            </>
          )}
          {!d.original_year && d.era && (
            <>
              <dt>成立</dt>
              <dd>{d.era}</dd>
            </>
          )}
          <dt>出典</dt>
          <dd>
            {d.source.url
              ? <a href={d.source.url} target="_blank" rel="noopener">{d.source.text}</a>
              : d.source.text}
            {d.source.base && <><br /><small>底本：{d.source.base}</small></>}
          </dd>
        </dl>
      </section>
    </header>

    {d.goals.length > 0 && (
      <section class="goals-box" aria-label="学習のめあて">
        <h2>学習のめあて</h2>
        <ul>
          {d.goals.map((g) => <li>{g}</li>)}
        </ul>
      </section>
    )}

    <section aria-label="本文">
      <div class="body-header no-print">
        <h2 style="margin: 0;">本文</h2>
        <div class="body-header__controls">
          {d.illustrations && d.illustrations.length > 0 && (
            <button
              type="button"
              class="scene-bg-toggle"
              data-scene-bg-toggle
              aria-pressed="true"
              title="本文の背景に挿絵を敷くかどうか"
            >
              <span aria-hidden="true">✦</span>
              <span class="scene-bg-toggle__label">背景挿絵</span>
            </button>
          )}
          <div class="tts-controls" data-tts-controls hidden>
            <button type="button" class="tts-btn" data-tts-play title="本文を読み上げる" aria-label="読み上げ">
              <span data-tts-icon-play aria-hidden="true">♪</span>
              <span data-tts-icon-pause aria-hidden="true" hidden>❚❚</span>
              <span class="tts-btn__label" data-tts-label>読み上げ</span>
            </button>
            <button type="button" class="tts-btn tts-btn--small" data-tts-stop title="停止" aria-label="停止" hidden>■</button>
            <select class="tts-select" data-tts-rate aria-label="読み上げ速度">
              <option value="0.8">ゆっくり</option>
              <option value="1" selected>標準</option>
              <option value="1.2">速め</option>
              <option value="1.5">速い</option>
            </select>
          </div>
        </div>
      </div>
      <div data-tts-body data-scene-bg-host data-illustrations={d.illustrations && d.illustrations.length > 0 ? JSON.stringify(d.illustrations.map((i) => ({ src: i.src, alt: i.alt, caption: i.caption }))) : ''}>
        <slot />
      </div>
    </section>

    {d.illustrations && d.illustrations.length > 0 && (
      <section aria-label="挿絵ギャラリー" class="illustrations-section no-print">
        <h2>挿絵ギャラリー</h2>
        <p class="illustrations-section__intro">
          物語の場面を、明治・大正期の児童書の挿絵を意識した和風水彩のタッチで表現しました。
        </p>
        <ol class="illustrations-grid">
          {d.illustrations.map((ill, idx) => (
            <li class="illustration-card">
              <figure>
                <img
                  src={ill.src}
                  alt={ill.alt ?? `${d.title} 挿絵 ${idx + 1}`}
                  loading="lazy"
                />
                {ill.caption && <figcaption>{ill.caption}</figcaption>}
              </figure>
            </li>
          ))}
        </ol>
      </section>
    )}

    {d.glossary.length > 0 && (
      <section aria-label="語句の意味">
        <h2>語句の意味</h2>
        <ul class="glossary-list">
          {d.glossary.map((g) => (
            <li>
              <span class="term">{g.term}</span>
              <span>{g.meaning}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {d.questions.length > 0 && (
      <section aria-label="考えてみよう">
        <h2>考えてみよう</h2>
        <ol class="questions-list">
          {d.questions.map((q) => <li>{q}</li>)}
        </ol>
      </section>
    )}

    {d.curriculum_items.length > 0 && (
      <section aria-label="指導要領との対応" class="no-print">
        <h2>指導要領との対応</h2>
        <p>
          このページは、文部科学省「{guidelineDoc}」{d.subject} 第{d.grade}学年の
          以下の指導事項を意識して編集しています。
        </p>
        <ul>
          {d.curriculum_items.map((c) => (
            <li><strong>{c.code}</strong> — {c.label}</li>
          ))}
        </ul>
        <p>
          <small>
            ※ 文部科学省告示の本文ではなく、編集者による要旨の言い換えです。
            正確な指導事項は<a href="https://www.mext.go.jp/a_menu/shotou/new-cs/" target="_blank" rel="noopener">文部科学省の公式資料</a>を参照してください。
          </small>
        </p>
      </section>
    )}

    {d.teaching_notes && (
      <details class="teaching-notes no-print" open>
        <summary>
          <span class="teaching-notes__badge">指導案</span>
          <span class="teaching-notes__hint">教員向け・授業展開の例</span>
        </summary>

        {d.teaching_notes.overview && (
          <p class="teaching-notes__overview">{d.teaching_notes.overview}</p>
        )}

        {(d.teaching_notes.target_time || d.teaching_notes.materials.length > 0) && (
          <dl class="teaching-notes__meta">
            {d.teaching_notes.target_time && (
              <>
                <dt>授業時数</dt>
                <dd>{d.teaching_notes.target_time}</dd>
              </>
            )}
            {d.teaching_notes.materials.length > 0 && (
              <>
                <dt>準備</dt>
                <dd>{d.teaching_notes.materials.join('、')}</dd>
              </>
            )}
          </dl>
        )}

        {d.teaching_notes.objectives.length > 0 && (
          <>
            <h3>指導目標</h3>
            <ul>
              {d.teaching_notes.objectives.map((o) => <li>{o}</li>)}
            </ul>
          </>
        )}

        {d.teaching_notes.flow.length > 0 && (
          <>
            <h3>授業の流れ</h3>
            <ol class="teaching-notes__flow">
              {d.teaching_notes.flow.map((step) => (
                <li>
                  {step.time && <span class="teaching-notes__time">{step.time}</span>}
                  <span>{step.activity}</span>
                </li>
              ))}
            </ol>
          </>
        )}

        {d.teaching_notes.discussion.length > 0 && (
          <>
            <h3>発問例・議論のポイント</h3>
            <ul>
              {d.teaching_notes.discussion.map((q) => <li>{q}</li>)}
            </ul>
          </>
        )}

        {d.teaching_notes.extensions.length > 0 && (
          <>
            <h3>発展課題</h3>
            <ul>
              {d.teaching_notes.extensions.map((e) => <li>{e}</li>)}
            </ul>
          </>
        )}

        <p class="teaching-notes__footer">
          ※ ここに書かれている内容はあくまで参考例です。授業者の判断と学級の実態に合わせて、自由に組み替えてご活用ください。
        </p>
      </details>
    )}

    {relatedTop.length > 0 && (
      <section aria-label="関連する教材" class="no-print">
        <h2>関連する教材</h2>
        <div class="lesson-grid">
          {relatedTop.map((r) => (
            <article class="lesson-card">
              <a href={`/library/${r.collection}/${r.lesson.id}`} class="lesson-card__link">
                <p class="lesson-card__meta">{COLLECTION_LABEL[r.collection]} ・ {r.reason}</p>
                <h3 class="lesson-card__title">{r.lesson.data.title}</h3>
                <p class="lesson-card__desc">{r.lesson.data.description}</p>
                <p class="lesson-card__author">
                  {r.lesson.data.author}
                  {r.lesson.data.era ? `（${r.lesson.data.era}）` : r.lesson.data.original_year ? `（${r.lesson.data.original_year}）` : ''}
                </p>
              </a>
            </article>
          ))}
        </div>
      </section>
    )}

    {/* ─── 学習メモ（ログイン中ユーザーのみ表示・クラウド同期）─── */}
    <section class="no-print lesson-notes" data-lesson-notes hidden>
      <h2>学習メモ</h2>
      <p class="lesson-notes__hint">
        ログイン中のユーザーのみ利用できます。記入は自動でクラウドに保存され、別端末からも参照できます。
      </p>
      <textarea
        class="lesson-notes__editor"
        data-lesson-notes-editor
        placeholder="この教材について気づいたこと、わからなかった語、自分の解釈、生徒の反応 …"
        rows="6"
        maxlength="8000"
      ></textarea>
      <div class="lesson-notes__footer">
        <span class="lesson-notes__status" data-lesson-notes-status aria-live="polite"></span>
        <span class="lesson-notes__count" data-lesson-notes-count>0 / 8000</span>
      </div>
    </section>

    <section aria-label="出典・ライセンス" class="no-print">
      <h2>出典・ライセンス</h2>
      <ul>
        <li><strong>原文</strong>: {d.author}「{d.title}」{d.original_year && `（${d.original_year}年）`}</li>
        <li>
          <strong>入力テキスト</strong>:
          {d.source.url
            ? <a href={d.source.url} target="_blank" rel="noopener">{d.source.text}</a>
            : d.source.text}
          {d.source.base && <>（底本：{d.source.base}）</>}
        </li>
        <li><strong>原文の権利</strong>: パブリックドメイン</li>
        <li>
          <strong>編集・語注・発問・解説</strong>:
          <a href="https://creativecommons.org/licenses/by/4.0/deed.ja" target="_blank" rel="license noopener">CC BY 4.0</a>
          &copy; project_procopios contributors
        </li>
      </ul>
    </section>
  </article>

  <script is:inline>
    // 本文の挿絵背景化：本文の <h3> セクション境界を見つけて、対応する挿絵を
    // 挿絵を viewport 固定の背景としてスクロール追従させる。
    // IntersectionObserver で h3 セクションの visibility を監視し、
    // 現在もっとも本文中央に近いセクションの挿絵を crossfade で表示。
    // ギャラリーは別途下部に残るので、本文を読んでいる前後（特に該当 h3
    // セクションが viewport の中央付近にあるとき）に挿絵が薄く浮かぶ。
    (function () {
      const STORAGE_KEY = 'hiraku.sceneBg.v1';
      const host = document.querySelector('[data-scene-bg-host]');
      const toggle = document.querySelector('[data-scene-bg-toggle]');
      if (!host) return;
      let illusts = [];
      try { illusts = JSON.parse(host.dataset.illustrations || '[]'); } catch (_) {}
      if (!illusts.length) return;

      // ─── 背景 canvas を body 直下に作成 ───
      let canvas = document.querySelector('[data-scene-bg-canvas]');
      if (!canvas) {
        canvas = document.createElement('div');
        canvas.className = 'scene-bg-canvas';
        canvas.setAttribute('data-scene-bg-canvas', '');
        canvas.setAttribute('aria-hidden', 'true');
        // 2 レイヤー: current（現在表示中）と next（次の場面、crossfade 用）
        const layerA = document.createElement('div');
        layerA.className = 'scene-bg-canvas__layer';
        layerA.dataset.layer = 'a';
        const layerB = document.createElement('div');
        layerB.className = 'scene-bg-canvas__layer';
        layerB.dataset.layer = 'b';
        const overlay = document.createElement('div');
        overlay.className = 'scene-bg-canvas__overlay';
        canvas.appendChild(layerA);
        canvas.appendChild(layerB);
        canvas.appendChild(overlay);
        document.body.insertBefore(canvas, document.body.firstChild);
      }
      const layers = canvas.querySelectorAll('.scene-bg-canvas__layer');
      let activeLayer = 0; // 0=a, 1=b

      // ─── h3 (またはなければ段落チャンク) ごとに data-scene-id を振る ───
      function markSections() {
        if (host.dataset.sceneMarked === '1') return;
        const children = Array.from(host.children);
        const h3idx = [];
        children.forEach((el, i) => {
          if (el.tagName === 'H3') h3idx.push(i);
        });
        let starts = [];
        if (h3idx.length > 0) {
          starts = h3idx;
        } else {
          // h3 が無い場合：段落を illustrations 数で均等分割
          const n = Math.min(illusts.length, Math.max(1, Math.ceil(children.length / 6)));
          const per = Math.ceil(children.length / n);
          for (let i = 0; i < n; i++) starts.push(i * per);
        }
        starts.forEach((startIdx, i) => {
          const illust = illusts[i];
          if (!illust) return;
          const el = children[startIdx];
          if (!el) return;
          el.setAttribute('data-scene-marker', String(i));
          el.setAttribute('data-scene-src', illust.src);
          if (illust.alt) el.setAttribute('data-scene-alt', illust.alt);
        });
        host.dataset.sceneMarked = '1';
      }

      function setCurrent(idx) {
        const illust = illusts[idx];
        if (!illust) return;
        const cur = layers[activeLayer];
        const next = layers[1 - activeLayer];
        // すでに表示中の画像と同じならスキップ
        const url = 'url("' + illust.src + '")';
        if (next.style.backgroundImage === url || cur.style.backgroundImage === url) {
          if (cur.style.backgroundImage === url) return; // 何もしない
        }
        next.style.backgroundImage = url;
        next.classList.add('is-current');
        cur.classList.remove('is-current');
        activeLayer = 1 - activeLayer;
      }

      let observer = null;
      function startObserving() {
        if (observer) return;
        markSections();
        const markers = host.querySelectorAll('[data-scene-marker]');
        if (!markers.length) return;
        // viewport の中央付近に来たセクションをアクティブにする
        observer = new IntersectionObserver(
          (entries) => {
            // viewport 中央に最も近い entry を選ぶ
            let bestIdx = null;
            let bestDist = Infinity;
            const center = window.innerHeight / 2;
            entries.forEach((e) => {
              if (!e.isIntersecting) return;
              const rect = e.target.getBoundingClientRect();
              const elCenter = rect.top + rect.height / 2;
              const dist = Math.abs(elCenter - center);
              if (dist < bestDist) {
                bestDist = dist;
                bestIdx = parseInt(e.target.getAttribute('data-scene-marker'), 10);
              }
            });
            // 全 marker から、最後に visible になったもの（=現在 viewport 内のもの）を再計算
            const allMarkers = Array.from(host.querySelectorAll('[data-scene-marker]'));
            allMarkers.forEach((m) => {
              const r = m.getBoundingClientRect();
              const elCenter = r.top + r.height / 2;
              const isInView = r.top < window.innerHeight && r.bottom > 0;
              if (isInView) {
                const dist = Math.abs(elCenter - center);
                if (dist < bestDist) {
                  bestDist = dist;
                  bestIdx = parseInt(m.getAttribute('data-scene-marker'), 10);
                }
              }
            });
            if (bestIdx !== null) setCurrent(bestIdx);
          },
          {
            // 中央 60% の領域に入ったら反応
            rootMargin: '-20% 0% -20% 0%',
            threshold: [0, 0.1, 0.5, 1.0],
          }
        );
        markers.forEach((m) => observer.observe(m));
        // 初期表示：先頭のシーンを敷く
        setCurrent(0);
      }
      function stopObserving() {
        if (observer) {
          observer.disconnect();
          observer = null;
        }
        layers.forEach((l) => l.classList.remove('is-current'));
      }
      function applyState(on) {
        canvas.classList.toggle('is-active', on);
        document.body.classList.toggle('has-scene-bg-canvas', on);
        if (toggle) toggle.setAttribute('aria-pressed', String(on));
        host.classList.toggle('has-scene-bg', on);
        if (on) startObserving(); else stopObserving();
      }
      const saved = (() => { try { return localStorage.getItem(STORAGE_KEY); } catch (_) { return null; } })();
      const initial = saved === null ? true : saved === '1';
      applyState(initial);
      toggle && toggle.addEventListener('click', () => {
        const next = toggle.getAttribute('aria-pressed') !== 'true';
        try { localStorage.setItem(STORAGE_KEY, next ? '1' : '0'); } catch (_) {}
        applyState(next);
        if (window.HirakuAuth) window.HirakuAuth.scheduleSync();
      });
    })();
  </script>

  <script is:inline>
    // 本文読み上げ（Web Speech API）。日本語の SpeechSynthesis 音声があるブラウザのみで動作。
    (function () {
      if (!('speechSynthesis' in window)) return;
      const controls = document.querySelector('[data-tts-controls]');
      const body = document.querySelector('[data-tts-body]');
      if (!controls || !body) return;

      // 日本語音声が利用できるか確認（voices は非同期で来る環境がある）
      function pickJapaneseVoice() {
        const voices = speechSynthesis.getVoices();
        return voices.find((v) => v.lang.startsWith('ja')) || voices.find((v) => /Japanese|Kyoko|Otoya/i.test(v.name));
      }
      function tryShowControls() {
        const v = pickJapaneseVoice();
        if (v) { controls.hidden = false; controls.dataset.ttsVoice = v.name; }
      }
      tryShowControls();
      speechSynthesis.onvoiceschanged = tryShowControls;

      const playBtn = controls.querySelector('[data-tts-play]');
      const stopBtn = controls.querySelector('[data-tts-stop]');
      const iconPlay = controls.querySelector('[data-tts-icon-play]');
      const iconPause = controls.querySelector('[data-tts-icon-pause]');
      const labelEl = controls.querySelector('[data-tts-label]');
      const rateSelect = controls.querySelector('[data-tts-rate]');

      // 本文を ruby 抜きの素文字列で取得し、句読点や改行で文単位に分割する
      function extractText() {
        const clone = body.cloneNode(true);
        // <rt> は読み仮名なので除去（ruby の親文字だけ残す）
        clone.querySelectorAll('rt, rp').forEach((el) => el.remove());
        // 連続改行や空行を正規化
        return clone.textContent.replace(/\s+/g, ' ').trim();
      }
      function splitIntoSentences(text) {
        // 「。」「！」「？」「.」「!」「?」で区切る。区切り文字は残す。
        const parts = text.split(/(?<=[。．！？!?])\s*/);
        return parts.filter((s) => s.trim().length > 0);
      }

      const sentences = splitIntoSentences(extractText());
      let idx = 0;
      let isPlaying = false;
      let isPaused = false;

      function utter(s) {
        const u = new SpeechSynthesisUtterance(s);
        u.lang = 'ja-JP';
        u.rate = parseFloat(rateSelect.value);
        u.pitch = 1;
        const voiceName = controls.dataset.ttsVoice;
        if (voiceName) {
          const v = speechSynthesis.getVoices().find((vv) => vv.name === voiceName);
          if (v) u.voice = v;
        }
        return u;
      }

      function speakFrom(i) {
        speechSynthesis.cancel();
        if (i >= sentences.length) { reset(); return; }
        idx = i;
        const u = utter(sentences[i]);
        u.onend = () => {
          if (isPlaying && !isPaused) speakFrom(i + 1);
        };
        u.onerror = () => reset();
        speechSynthesis.speak(u);
      }

      function setPlayingUI(playing) {
        isPlaying = playing;
        iconPlay.hidden = playing;
        iconPause.hidden = !playing;
        labelEl.textContent = playing ? '一時停止' : (idx > 0 && idx < sentences.length ? '続きから再生' : '読み上げ');
        stopBtn.hidden = !playing && idx === 0;
      }
      function reset() {
        speechSynthesis.cancel();
        idx = 0;
        isPlaying = false;
        isPaused = false;
        setPlayingUI(false);
        stopBtn.hidden = true;
      }

      playBtn.addEventListener('click', () => {
        if (isPlaying && !isPaused) {
          speechSynthesis.pause();
          isPaused = true;
          setPlayingUI(false);
          stopBtn.hidden = false;
          return;
        }
        if (isPaused) {
          speechSynthesis.resume();
          isPaused = false;
          setPlayingUI(true);
          return;
        }
        // 新規再生
        setPlayingUI(true);
        speakFrom(idx);
      });
      stopBtn.addEventListener('click', reset);
      rateSelect.addEventListener('change', () => {
        if (isPlaying) {
          // rate 変更時は現在の文から speak し直し
          speakFrom(idx);
        }
      });

      // ページを離れたら停止
      window.addEventListener('beforeunload', () => speechSynthesis.cancel());
    })();

    // ─── 英語単語クリック発音 ───────────
    // kotokoeigo1 など subject === '英語' の教材でのみ有効化。
    // 本文内の英単語（連続したアスキー英字）をクリックすると、
    // Web Speech API で en-US 音声で読み上げる。
    // また blockquote.song（例文ブロック）には「▶ 発音」ボタンを付与し
    // 一文単位で読み上げる。クリックした単語は localStorage に保存され、
    // 同ページ上に「最近の単語」リストとして表示される。
    (function () {
      if (!('speechSynthesis' in window)) return;
      const article = document.querySelector('article[data-lesson-subject]');
      const isEnglish = article && article.dataset.lessonSubject === '英語';
      if (!isEnglish) return;
      const host = document.querySelector('[data-tts-body]');
      if (!host) return;

      const STORAGE_KEY = 'hiraku.englishWords.v1';
      function loadHistory() {
        try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch (_) { return []; }
      }
      function saveHistory(arr) {
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(arr.slice(0, 40))); } catch (_) {}
        if (window.HirakuAuth) window.HirakuAuth.scheduleSync();
      }
      function addToHistory(word) {
        const w = word.toLowerCase();
        let arr = loadHistory();
        arr = arr.filter((x) => x !== w);
        arr.unshift(w);
        saveHistory(arr);
        renderHistoryPanel();
      }

      function pickEnglishVoice() {
        const voices = speechSynthesis.getVoices();
        // 優先: en-US の自然な声 (Google, Samantha, Alex, Daniel)
        return (
          voices.find((v) => v.lang === 'en-US' && /Samantha|Alex|Google US/i.test(v.name)) ||
          voices.find((v) => v.lang === 'en-US') ||
          voices.find((v) => v.lang.startsWith('en'))
        );
      }
      function speakEnglish(text, rate) {
        speechSynthesis.cancel();
        const u = new SpeechSynthesisUtterance(text);
        u.lang = 'en-US';
        u.rate = rate || 0.92;
        u.pitch = 1;
        const v = pickEnglishVoice();
        if (v) u.voice = v;
        speechSynthesis.speak(u);
      }

      // ─── 本文のクリックで単語を発音 ───
      host.addEventListener('click', (e) => {
        // すでにボタン等のクリックを処理しているとき以外、選択範囲を確認
        const sel = window.getSelection();
        if (sel && sel.toString().trim().length > 0) {
          // ハイライト選択された文字列をそのまま読む
          const text = sel.toString().trim();
          if (/[A-Za-z]/.test(text)) {
            speakEnglish(text);
            // 単語と判定できるものだけ履歴に保存
            if (/^[A-Za-z][A-Za-z\-']*$/.test(text)) addToHistory(text);
            highlightFlash(e.target);
            return;
          }
        }
        // ダブルクリックでなくとも、テキストノードの単語位置を特定して発音
        const target = e.target;
        if (!(target instanceof Element)) return;
        // ボタン・リンク・入力欄等は除外
        if (target.closest('a, button, input, textarea, select, [data-tts-controls], [data-scene-bg-toggle]')) return;
        // クリック位置から単語を抽出
        const range = caretRangeFromPoint(e.clientX, e.clientY);
        if (!range) return;
        const node = range.startContainer;
        if (node.nodeType !== Node.TEXT_NODE) return;
        const offset = range.startOffset;
        const text = node.textContent || '';
        // 単語境界を探す
        let start = offset;
        let end = offset;
        while (start > 0 && /[A-Za-z\-']/.test(text[start - 1])) start--;
        while (end < text.length && /[A-Za-z\-']/.test(text[end])) end++;
        const word = text.slice(start, end);
        if (word.length < 2) return;
        if (!/^[A-Za-z][A-Za-z\-']*$/.test(word)) return;
        speakEnglish(word);
        addToHistory(word);
        highlightFlash(e.target);
      });

      function caretRangeFromPoint(x, y) {
        if (document.caretRangeFromPoint) return document.caretRangeFromPoint(x, y);
        if (document.caretPositionFromPoint) {
          const p = document.caretPositionFromPoint(x, y);
          if (!p) return null;
          const r = document.createRange();
          r.setStart(p.offsetNode, p.offset);
          r.setEnd(p.offsetNode, p.offset);
          return r;
        }
        return null;
      }

      function highlightFlash(el) {
        if (!el || !el.classList) return;
        el.classList.add('word-flash');
        setTimeout(() => el.classList.remove('word-flash'), 600);
      }

      // ─── blockquote (例文) に「▶ 発音」ボタンを付与 ───
      host.querySelectorAll('blockquote').forEach((bq) => {
        // 既に追加済みならスキップ
        if (bq.querySelector('.eng-play-btn')) return;
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'eng-play-btn no-print';
        btn.setAttribute('aria-label', 'この例文を発音');
        btn.title = 'この例文を発音';
        btn.innerHTML = '<span aria-hidden="true">♪</span> 発音';
        btn.addEventListener('click', (ev) => {
          ev.stopPropagation();
          // <rt> や注釈などは除いてテキストを取得
          const clone = bq.cloneNode(true);
          clone.querySelectorAll('.eng-play-btn, rt, rp, .word-history-panel').forEach((el) => el.remove());
          const text = clone.textContent.replace(/\s+/g, ' ').trim();
          if (text) speakEnglish(text, 0.88);
        });
        bq.appendChild(btn);
      });

      // ─── 最近クリックした単語パネル ───
      function renderHistoryPanel() {
        let panel = document.querySelector('[data-eng-word-history]');
        const arr = loadHistory();
        if (arr.length === 0) {
          if (panel) panel.hidden = true;
          return;
        }
        if (!panel) {
          panel = document.createElement('aside');
          panel.className = 'word-history-panel no-print';
          panel.setAttribute('data-eng-word-history', '');
          panel.innerHTML =
            '<h4>最近聞いた単語 <span class="word-history-panel__hint">クリックでもう一度発音</span></h4>' +
            '<div class="word-history-panel__list" data-eng-history-list></div>' +
            '<button type="button" class="word-history-panel__clear" data-eng-history-clear>すべて消去</button>';
          host.parentNode.insertBefore(panel, host.nextSibling);
          // クリックでもう一度発音
          panel.addEventListener('click', (e) => {
            const target = e.target;
            if (target.matches('[data-eng-history-clear]')) {
              try { localStorage.removeItem(STORAGE_KEY); } catch (_) {}
              renderHistoryPanel();
              return;
            }
            if (target.matches('[data-eng-history-word]')) {
              speakEnglish(target.textContent);
            }
          });
        }
        panel.hidden = false;
        const list = panel.querySelector('[data-eng-history-list]');
        list.innerHTML = '';
        arr.forEach((w) => {
          const chip = document.createElement('button');
          chip.type = 'button';
          chip.className = 'word-history-chip';
          chip.setAttribute('data-eng-history-word', '');
          chip.textContent = w;
          list.appendChild(chip);
        });
      }
      renderHistoryPanel();
    })();
  </script>

  <script is:inline>
    // ─── ブックマーク・続きから読む機能 ───
    // 教材本文のスクロール位置を localStorage に記録し、再訪時に
    // 「前回ここまで読みました」チップを画面右下に出して、ワンクリックで
    // その位置に復帰できるようにする。最大 20 件まで保持し、古いものから捨てる。
    // 同じデータをホームページの「続きを読む」ウィジェットでも読む。
    (function () {
      const article = document.querySelector('article[data-lesson-collection]');
      if (!article) return;
      const collection = article.dataset.lessonCollection;
      const id = article.dataset.lessonId;
      const title = article.dataset.lessonTitle || document.title;
      const author = article.dataset.lessonAuthor || '';
      const path = '/library/' + collection + '/' + id;
      const STORAGE_KEY = 'hiraku.bookmarks.v1';
      const MAX_BOOKMARKS = 20;
      const SAVE_THRESHOLD = 240; // 240px 以上スクロールしないと保存しない（ヘッダーだけ見て離脱した場合を除外）
      const COMPLETE_RATIO = 0.92; // 92% 以上スクロールしたら「読了」として削除

      function readBookmarks() {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          if (!raw) return { lessons: {} };
          const parsed = JSON.parse(raw);
          if (!parsed || typeof parsed !== 'object' || !parsed.lessons) return { lessons: {} };
          return parsed;
        } catch (_) { return { lessons: {} }; }
      }

      function writeBookmarks(data) {
        try {
          // MAX 件数を超えたら最古の ts のものから削除
          const entries = Object.entries(data.lessons);
          if (entries.length > MAX_BOOKMARKS) {
            entries.sort((a, b) => (b[1].ts || 0) - (a[1].ts || 0));
            const keep = entries.slice(0, MAX_BOOKMARKS);
            data.lessons = Object.fromEntries(keep);
          }
          localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
        } catch (_) {}
        if (window.HirakuAuth) window.HirakuAuth.scheduleSync();
      }

      function deleteBookmark() {
        const data = readBookmarks();
        if (data.lessons[path]) {
          delete data.lessons[path];
          writeBookmarks(data);
        }
      }

      function saveBookmark() {
        const scrollY = window.scrollY;
        const docH = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
        const progress = Math.min(1, scrollY / docH);
        // 読了 or ヘッダーのみは削除
        if (progress >= COMPLETE_RATIO || scrollY < SAVE_THRESHOLD) {
          deleteBookmark();
          return;
        }
        const data = readBookmarks();
        data.lessons[path] = {
          collection: collection,
          id: id,
          title: title,
          author: author,
          path: path,
          scrollY: scrollY,
          progress: progress,
          ts: Date.now(),
        };
        writeBookmarks(data);
      }

      // ─── スクロール停止 1.2 秒後に保存 ───
      let saveTimer = null;
      function scheduleSave() {
        if (saveTimer) clearTimeout(saveTimer);
        saveTimer = setTimeout(saveBookmark, 1200);
      }
      window.addEventListener('scroll', scheduleSave, { passive: true });
      window.addEventListener('beforeunload', saveBookmark);
      // Page Visibility 変化時にも保存（モバイルブラウザ・タブ切替対応）
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'hidden') saveBookmark();
      });

      // ─── 再訪時に復帰チップを表示 ───
      function showResumeChip() {
        const data = readBookmarks();
        const bookmark = data.lessons[path];
        if (!bookmark || typeof bookmark.scrollY !== 'number') return;
        // 既に該当位置付近にいる、または手動でその位置を超えている場合は出さない
        if (Math.abs(window.scrollY - bookmark.scrollY) < 200) return;

        const chip = document.createElement('div');
        chip.className = 'resume-chip no-print';
        chip.setAttribute('role', 'dialog');
        chip.setAttribute('aria-label', '前回の続きから読む');
        const pct = Math.round((bookmark.progress || 0) * 100);
        chip.innerHTML =
          '<div class="resume-chip__label">前回ここまで読みました</div>' +
          '<div class="resume-chip__progress"><span class="resume-chip__bar" style="width:' + pct + '%"></span><span class="resume-chip__pct">' + pct + '%</span></div>' +
          '<div class="resume-chip__actions">' +
            '<button type="button" class="resume-chip__resume" data-resume>続きから読む →</button>' +
            '<button type="button" class="resume-chip__dismiss" data-dismiss aria-label="閉じる">×</button>' +
          '</div>';
        document.body.appendChild(chip);
        // 0.3 秒後にアニメーション in
        requestAnimationFrame(() => chip.classList.add('is-visible'));

        chip.querySelector('[data-resume]').addEventListener('click', () => {
          // smooth スクロールで該当位置へ
          window.scrollTo({ top: bookmark.scrollY, behavior: 'smooth' });
          chip.classList.remove('is-visible');
          setTimeout(() => chip.remove(), 300);
        });
        chip.querySelector('[data-dismiss]').addEventListener('click', () => {
          chip.classList.remove('is-visible');
          setTimeout(() => chip.remove(), 300);
        });
        // ユーザーがスクロールし始めたら自動で閉じる
        const onScroll = () => {
          if (Math.abs(window.scrollY - 0) > 100) {
            chip.classList.remove('is-visible');
            setTimeout(() => chip.remove(), 300);
            window.removeEventListener('scroll', onScroll);
          }
        };
        // 既にスクロール済みの場合は表示しない（早期return済みなので、ここでは初回のみ）
        if (window.scrollY < 100) window.addEventListener('scroll', onScroll, { passive: true });
      }

      // ロード直後に表示判定（少し遅延：他のスクリプトの初期スクロール後に判断）
      if (document.readyState === 'complete') {
        setTimeout(showResumeChip, 400);
      } else {
        window.addEventListener('load', () => setTimeout(showResumeChip, 400));
      }
    })();
  </script>

  <script is:inline>
    // ─── 教材メモ (ログイン中のみ表示。/api/notes と連動) ───
    (function () {
      const section = document.querySelector('[data-lesson-notes]');
      const editor = document.querySelector('[data-lesson-notes-editor]');
      const status = document.querySelector('[data-lesson-notes-status]');
      const counter = document.querySelector('[data-lesson-notes-count]');
      const article = document.querySelector('article[data-lesson-collection]');
      if (!section || !editor || !article) return;
      const collection = article.dataset.lessonCollection;
      const id = article.dataset.lessonId;
      const title = article.dataset.lessonTitle;
      if (!collection || !id) return;

      let saveTimer = null;
      let initialLoaded = false;

      function applyVisibility() {
        const u = (window.HirakuAuth && window.HirakuAuth.getUser && window.HirakuAuth.getUser()) || null;
        section.hidden = !u;
        if (u && !initialLoaded) loadFromServer();
      }
      function updateCounter() {
        const n = (editor.value || '').length;
        if (counter) counter.textContent = n + ' / 8000';
      }

      async function loadFromServer() {
        try {
          const url = '/api/notes?collection=' + encodeURIComponent(collection) +
                      '&id=' + encodeURIComponent(id);
          const resp = await fetch(url, { credentials: 'same-origin', cache: 'no-store' });
          if (!resp.ok) throw new Error('HTTP ' + resp.status);
          const data = await resp.json();
          if (data.note && typeof data.note.text === 'string') {
            editor.value = data.note.text;
          }
          updateCounter();
          initialLoaded = true;
        } catch (_) {
          if (status) status.textContent = '読み込みに失敗 (オフライン?)';
        }
      }

      async function saveNow() {
        if (!window.HirakuAuth || !window.HirakuAuth.isSignedIn()) return;
        try {
          if (status) status.textContent = '保存中…';
          const resp = await fetch('/api/notes', {
            method: 'PUT',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              collection,
              id,
              title,
              text: editor.value || '',
            }),
          });
          if (!resp.ok) throw new Error('HTTP ' + resp.status);
          if (status) status.textContent = '保存しました ' + new Date().toLocaleTimeString('ja-JP');
        } catch (_) {
          if (status) status.textContent = '保存に失敗 (オフライン?) — 後で自動再試行';
        }
      }

      function scheduleSave() {
        updateCounter();
        if (saveTimer) clearTimeout(saveTimer);
        if (status) status.textContent = '入力中…';
        saveTimer = setTimeout(saveNow, 1500);
      }

      editor.addEventListener('input', scheduleSave);
      editor.addEventListener('blur', () => {
        if (saveTimer) { clearTimeout(saveTimer); saveTimer = null; }
        saveNow();
      });
      window.addEventListener('beforeunload', () => {
        if (saveTimer) { clearTimeout(saveTimer); saveNow(); }
      });

      window.addEventListener('hiraku:auth', applyVisibility);
      // 初期化
      const tryInit = () => {
        if (window.HirakuAuth) applyVisibility();
        else setTimeout(tryInit, 100);
      };
      tryInit();
      updateCounter();
    })();
  </script>
