---
/**
 * ReaderMode レイアウト — 没入型読書のためのフルスクリーンレイアウト。
 *
 * - ヘッダー / フッター / 下部ナビ非表示
 * - 縦書き既定（ヘッダーの A11y 設定とは独立で、URL で発動）
 * - 上部フローティング操作（戻る・章送り・設定）
 * - ESC で通常ページに戻る
 */
import type { CollectionEntry } from 'astro:content';
import '../styles/global.css';

type AnyLesson =
  | CollectionEntry<'kokugo3'>
  | CollectionEntry<'kokugo4'>
  | CollectionEntry<'kokugo6'>
  | CollectionEntry<'chugaku1'>
  | CollectionEntry<'chugaku2'>
  | CollectionEntry<'kotoko1'>
  | CollectionEntry<'chugakurika1'>
  | CollectionEntry<'kotokoeigo1'>
  | CollectionEntry<'sansu5'>
  | CollectionEntry<'chugakukomin3'>;

interface NavRef {
  href: string;
  title: string;
}

interface Props {
  lesson: AnyLesson;
  collection: string;
  prev?: NavRef | null;
  next?: NavRef | null;
}

const { lesson, collection, prev, next } = Astro.props;
const d = lesson.data;
const lessonUrl = `/library/${collection}/${lesson.id}`;
---

<!doctype html>
<html lang="ja" data-reader-mode>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{d.title} — リーダーモード | ひらく</title>
    <meta name="description" content={d.description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@500;700&display=swap"
    />
    <style>
      :root[data-reader-mode] body { background: var(--bg); margin: 0; }
      .reader-shell { min-height: 100vh; display: flex; flex-direction: column; }
      .reader-topbar {
        position: fixed; top: 0; left: 0; right: 0; z-index: 10;
        display: flex; align-items: center; justify-content: space-between;
        padding: 0.6rem 1rem;
        background: color-mix(in srgb, var(--bg) 88%, transparent);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--border);
      }
      .reader-topbar__left, .reader-topbar__right {
        display: flex; gap: 0.5rem; align-items: center;
      }
      .reader-topbar__title {
        font-family: var(--font-serif); font-weight: 700;
        font-size: 0.95rem; color: var(--text);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        max-width: 50vw;
      }
      .reader-topbar__meta {
        font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em;
        text-transform: uppercase; color: var(--text-soft); margin-right: 0.5rem;
      }
      .reader-topbar a, .reader-topbar button {
        display: inline-flex; align-items: center; justify-content: center;
        width: 36px; height: 36px;
        border: 1px solid var(--border); border-radius: 50%;
        color: var(--text-soft); background: transparent;
        text-decoration: none; cursor: pointer; font-size: 1rem;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
      }
      .reader-topbar a:hover, .reader-topbar button:hover {
        background: var(--bg-soft); color: var(--text); border-color: var(--text-soft);
      }
      .reader-topbar a.disabled, .reader-topbar a[aria-disabled="true"] {
        opacity: 0.35; pointer-events: none;
      }

      .reader-main {
        flex: 1;
        padding: 5rem 2rem 4rem;
        max-width: 100vw;
        margin: 0 auto;
        overflow-x: auto;
      }

      .reader-title {
        font-family: var(--font-serif);
        font-size: clamp(1.6rem, 3.2vw, 2.2rem);
        font-weight: 700;
        margin: 0 0 0.4rem;
        line-height: 1.35;
      }
      .reader-byline {
        font-family: var(--font-sans);
        font-size: 0.95rem;
        color: var(--text-soft);
        margin: 0 0 2rem;
      }

      /* デフォルトで縦書き（リーダーモード専用） */
      .reader-body {
        writing-mode: vertical-rl;
        -webkit-writing-mode: vertical-rl;
        text-orientation: mixed;
        font-family: var(--font-serif);
        font-size: calc(1.15rem * var(--font-size-scale));
        line-height: 1.95;
        letter-spacing: 0.02em;
        height: calc(100vh - 16rem);
        min-height: 480px;
        padding: 1rem 0;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
      }
      .reader-body p {
        margin: 0 0.35em;
        text-indent: 0;
      }
      .reader-body h3 {
        font-family: var(--font-serif);
        font-size: 1.15em;
        margin: 0 1em;
        padding: 0 0.5em;
        writing-mode: vertical-rl;
        border-right: 2px solid var(--accent);
        border-bottom: none;
      }
      .reader-body blockquote.song {
        margin: 0 0.8em;
        padding: 0.4em 0.8em;
        border-right: 3px solid var(--accent-soft);
        border-left: 0;
        background: var(--bg-soft);
      }
      .reader-body rt {
        font-size: 0.5em; color: var(--text-soft); font-family: var(--font-sans);
      }

      /* 横書きモード（リーダーモード内でユーザーが切り替えた場合） */
      :root[data-reader-writing="horizontal"] .reader-body {
        writing-mode: horizontal-tb;
        height: auto;
        max-width: 720px;
        margin: 0 auto;
        padding: 1.5rem 0;
      }
      :root[data-reader-writing="horizontal"] .reader-body p {
        margin: 0.5em 0;
      }
      :root[data-reader-writing="horizontal"] .reader-body h3 {
        writing-mode: horizontal-tb;
        border-right: 0;
        border-bottom: 2px solid var(--accent);
        padding: 0.3em 0;
        margin: 1.5em 0 0.5em;
      }
      :root[data-reader-writing="horizontal"] .reader-body blockquote.song {
        border-right: 0;
        border-left: 3px solid var(--accent-soft);
      }

      .reader-footer {
        position: fixed; bottom: 0; left: 0; right: 0; z-index: 10;
        display: flex; justify-content: space-between; align-items: center;
        padding: 0.5rem 1rem;
        background: color-mix(in srgb, var(--bg) 88%, transparent);
        backdrop-filter: blur(8px);
        border-top: 1px solid var(--border);
        font-size: 0.85rem; color: var(--text-soft);
      }
      .reader-footer__chip {
        font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em;
      }
      .reader-footer__hint { font-size: 0.78rem; }

      .reader-panel {
        position: fixed; top: 4rem; right: 1rem; z-index: 20;
        background: var(--bg-elevated); border: 1px solid var(--border);
        border-radius: 8px; padding: 0.8rem 1rem;
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        min-width: 240px; display: none;
        font-size: 0.88rem;
      }
      .reader-panel.is-open { display: block; }
      .reader-panel__row {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0.35rem 0; border-bottom: 1px solid var(--border-soft);
      }
      .reader-panel__row:last-child { border-bottom: 0; }
      .reader-panel__btn {
        background: transparent; border: 1px solid var(--border);
        color: var(--text); padding: 0.18rem 0.55rem; border-radius: 4px;
        cursor: pointer; font-size: 0.82rem; font-family: var(--font-sans);
        margin-left: 0.2rem;
      }
      .reader-panel__btn:hover { background: var(--bg-soft); }
      .reader-panel__btn[aria-pressed="true"] {
        background: var(--logo-bg); color: var(--logo-fg); border-color: var(--logo-bg);
      }

      @media (max-width: 767px) {
        .reader-main { padding: 4.5rem 1rem 3.5rem; }
        .reader-body { height: calc(100vh - 14rem); }
        .reader-topbar__title { max-width: 40vw; }
      }
    </style>
  </head>
  <body>
    <div class="reader-shell">
      <header class="reader-topbar" role="banner">
        <div class="reader-topbar__left">
          <a href={lessonUrl} title="通常表示に戻る" aria-label="通常表示に戻る">×</a>
          <span class="reader-topbar__meta">{d.subject} 第{d.grade}学年</span>
          <span class="reader-topbar__title">{d.title}</span>
        </div>
        <div class="reader-topbar__right">
          <a
            href={prev ? prev.href : '#'}
            title={prev ? `前の教材：${prev.title}` : '前の教材なし'}
            aria-label={prev ? `前の教材：${prev.title}` : '前の教材なし'}
            aria-disabled={prev ? undefined : 'true'}
            class={prev ? '' : 'disabled'}
          >←</a>
          <a
            href={next ? next.href : '#'}
            title={next ? `次の教材：${next.title}` : '次の教材なし'}
            aria-label={next ? `次の教材：${next.title}` : '次の教材なし'}
            aria-disabled={next ? undefined : 'true'}
            class={next ? '' : 'disabled'}
          >→</a>
          <button type="button" title="表示設定" aria-label="表示設定" data-reader-settings>Aa</button>
        </div>
      </header>

      <div class="reader-panel" data-reader-panel role="dialog" aria-label="リーダーモード設定">
        <div class="reader-panel__row">
          <span>書字</span>
          <div>
            <button type="button" class="reader-panel__btn" data-reader-writing-set="vertical">縦</button>
            <button type="button" class="reader-panel__btn" data-reader-writing-set="horizontal">横</button>
          </div>
        </div>
        <div class="reader-panel__row">
          <span>文字サイズ</span>
          <div>
            <button type="button" class="reader-panel__btn" data-fs-set="0.9">A-</button>
            <button type="button" class="reader-panel__btn" data-fs-set="1">A</button>
            <button type="button" class="reader-panel__btn" data-fs-set="1.15">A+</button>
            <button type="button" class="reader-panel__btn" data-fs-set="1.3">A++</button>
          </div>
        </div>
        <div class="reader-panel__row">
          <span>ふりがな</span>
          <div>
            <button type="button" class="reader-panel__btn" data-ruby-set="on">表示</button>
            <button type="button" class="reader-panel__btn" data-ruby-set="off">非表示</button>
          </div>
        </div>
      </div>

      <main class="reader-main">
        <h1 class="reader-title">{d.title}</h1>
        <p class="reader-byline">
          {d.author}{d.author_dates ? `（${d.author_dates}）` : ''}
          {d.original_year && ` ・ ${d.original_year}年`}
        </p>
        <div class="reader-body story-body">
          <slot />
        </div>
      </main>

      <footer class="reader-footer">
        <span class="reader-footer__chip">READER MODE</span>
        <span class="reader-footer__hint">
          {prev || next ? '← / → で章を送る　・　ESC で戻る' : 'ESC で戻る'}
        </span>
      </footer>
    </div>

    <script src="/progress.js" is:inline></script>
    <script is:inline>
      const root = document.documentElement;
      const ls = window.localStorage;

      // Setting panel toggle
      const settingsBtn = document.querySelector('[data-reader-settings]');
      const panel = document.querySelector('[data-reader-panel]');
      settingsBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        panel.classList.toggle('is-open');
      });
      document.addEventListener('click', (e) => {
        if (panel && !panel.contains(e.target) && e.target !== settingsBtn) {
          panel.classList.remove('is-open');
        }
      });

      // Writing direction (per-reader-mode, separate from global)
      function applyReaderWriting(v) {
        root.setAttribute('data-reader-writing', v);
        document.querySelectorAll('[data-reader-writing-set]').forEach((b) => {
          b.setAttribute('aria-pressed', String(b.dataset.readerWritingSet === v));
        });
      }
      function applyFontSize(v) {
        root.style.setProperty('--font-size-scale', v);
        document.querySelectorAll('[data-fs-set]').forEach((b) => {
          b.setAttribute('aria-pressed', String(b.dataset.fsSet === v));
        });
      }
      function applyRuby(v) {
        if (v === 'on') root.removeAttribute('data-ruby');
        else root.setAttribute('data-ruby', v);
        document.querySelectorAll('[data-ruby-set]').forEach((b) => {
          b.setAttribute('aria-pressed', String(b.dataset.rubySet === v));
        });
      }

      // 初期値（リーダーモードでは縦書きが基本だが、ユーザーの選択を尊重）
      applyReaderWriting(ls.getItem('readerWriting') || 'vertical');
      applyFontSize(ls.getItem('fontSize') || '1');
      applyRuby(ls.getItem('ruby') || 'on');

      document.querySelectorAll('[data-reader-writing-set]').forEach((b) => {
        b.addEventListener('click', () => {
          const v = b.dataset.readerWritingSet;
          ls.setItem('readerWriting', v);
          applyReaderWriting(v);
        });
      });
      document.querySelectorAll('[data-fs-set]').forEach((b) => {
        b.addEventListener('click', () => {
          const v = b.dataset.fsSet;
          ls.setItem('fontSize', v);
          applyFontSize(v);
        });
      });
      document.querySelectorAll('[data-ruby-set]').forEach((b) => {
        b.addEventListener('click', () => {
          const v = b.dataset.rubySet;
          ls.setItem('ruby', v);
          applyRuby(v);
        });
      });

      // Keyboard navigation
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          location.href = '{lessonUrl}'.replace('{lessonUrl}', '');
          const closeLink = document.querySelector('.reader-topbar__left a[title="通常表示に戻る"]');
          if (closeLink) location.href = closeLink.getAttribute('href');
        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
          const prevLink = document.querySelector('.reader-topbar__right a[aria-label^="前の教材"]:not(.disabled)');
          if (prevLink) location.href = prevLink.getAttribute('href');
        } else if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
          const nextLink = document.querySelector('.reader-topbar__right a[aria-label^="次の教材"]:not(.disabled)');
          if (nextLink) location.href = nextLink.getAttribute('href');
        }
      });
    </script>
  </body>
</html>
