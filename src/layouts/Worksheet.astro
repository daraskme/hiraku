---
/**
 * Worksheet レイアウト — 教材を A4 で印刷できる体裁に整える。
 *
 * - 画面では Bookmarklet 風のラッパー（操作 UI 付き）
 * - print では本文＋問い欄＋出典のみ
 * - 名前・日付欄、各問いに記入スペース、改ページの最適化
 */
import type { CollectionEntry } from 'astro:content';
import '../styles/global.css';

type AnyLesson =
  | CollectionEntry<'kokugo1'>
  | CollectionEntry<'kokugo2'>
  | CollectionEntry<'kokugo3'>
  | CollectionEntry<'kokugo4'>
  | CollectionEntry<'kokugo6'>
  | CollectionEntry<'chugaku1'>
  | CollectionEntry<'chugaku2'>
  | CollectionEntry<'chugaku3'>
  | CollectionEntry<'kotoko1'>
  | CollectionEntry<'kotoko2'>
  | CollectionEntry<'kotoko3'>
  | CollectionEntry<'kateika5'>
  | CollectionEntry<'chugakurika1'>
  | CollectionEntry<'chugakurika2'>
  | CollectionEntry<'chugakurekishi1'>
  | CollectionEntry<'kotokoeigo1'>
  | CollectionEntry<'koteoyaku1'>
  | CollectionEntry<'sansu5'>
  | CollectionEntry<'chugakukomin3'>
  | CollectionEntry<'kotorekishi1'>
  | CollectionEntry<'kotokokanbun1'>
  | CollectionEntry<'kotosekaishi1'>;

interface Props {
  lesson: AnyLesson;
  collection: string;
}

const { lesson, collection } = Astro.props;
const d = lesson.data;
const lessonUrl = `/library/${collection}/${lesson.id}`;
const stageLabel: Record<string, string> = {
  shogaku: '小学校',
  chugaku: '中学校',
  kotoko: '高等学校',
};
const stage = stageLabel[d.school_stage] ?? '小学校';
---

<!doctype html>
<html lang="ja" data-worksheet-mode>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{d.title} — ワークシート | ひらく</title>
    <meta name="description" content={`「${d.title}」のワークシート印刷用ページ`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@500;700&display=swap"
    />
    <style>
      :root[data-worksheet-mode] body {
        margin: 0;
        background: #d8d3c5;
      }

      .ws-toolbar {
        position: sticky;
        top: 0;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.7rem 1rem;
        background: var(--bg);
        border-bottom: 1px solid var(--border);
      }
      .ws-toolbar a, .ws-toolbar button {
        display: inline-flex; align-items: center;
        height: 36px; padding: 0 0.9rem;
        border: 1px solid var(--border); border-radius: 999px;
        background: var(--bg-elevated); color: var(--text);
        font-family: var(--font-sans); font-size: 0.85rem;
        text-decoration: none; cursor: pointer;
      }
      .ws-toolbar button:hover, .ws-toolbar a:hover {
        background: var(--text); color: var(--bg); border-color: var(--text);
      }
      .ws-toolbar__hint {
        font-family: var(--font-mono); font-size: 0.75rem;
        color: var(--text-soft); letter-spacing: 0.06em;
      }

      /* ─── ワークシート本体（A4 体裁を画面でもプレビュー） ─── */
      .ws-page {
        background: white;
        color: #1a1a1a;
        max-width: 210mm;       /* A4 幅 */
        min-height: 297mm;      /* A4 高 */
        margin: 1.5rem auto;
        padding: 18mm 16mm;
        box-shadow: 0 6px 24px rgba(0, 0, 0, 0.12);
        font-family: var(--font-serif);
        line-height: 1.85;
        font-size: 13pt;
      }

      .ws-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
        padding-bottom: 0.6rem;
        border-bottom: 2px solid #1a1a1a;
      }
      .ws-header__brand {
        font-family: var(--font-mono);
        font-size: 9pt;
        letter-spacing: 0.15em;
        color: #666;
        text-transform: uppercase;
      }
      .ws-header__meta {
        font-family: var(--font-sans);
        font-size: 9pt;
        color: #444;
        text-align: right;
      }

      .ws-title {
        font-size: 22pt;
        font-weight: 700;
        margin: 0.4rem 0 0.3rem;
        line-height: 1.3;
      }
      .ws-author {
        font-family: var(--font-sans);
        font-size: 10pt;
        color: #444;
        margin: 0 0 1rem;
      }

      .ws-namebar {
        display: flex;
        gap: 1.5rem;
        margin: 0.4rem 0 1.2rem;
        font-family: var(--font-sans);
        font-size: 10pt;
      }
      .ws-namebar__field {
        flex: 1;
        display: flex;
        align-items: baseline;
        gap: 0.4rem;
        border-bottom: 1px solid #888;
        padding-bottom: 2px;
      }
      .ws-namebar__field span {
        color: #444;
        white-space: nowrap;
      }
      .ws-namebar__line {
        flex: 1;
        height: 1.4em;
      }

      .ws-section {
        margin: 1.2rem 0 0;
        padding-top: 0.6rem;
      }
      .ws-section__title {
        font-family: var(--font-sans);
        font-size: 11pt;
        letter-spacing: 0.08em;
        font-weight: 700;
        color: #1a1a1a;
        margin: 0 0 0.6rem;
        padding: 0.25rem 0.5rem;
        background: #efe9d8;
        border-left: 4px solid #1d2a3d;
      }
      .ws-body {
        font-size: 11.5pt;
        line-height: 1.9;
      }
      .ws-body p {
        margin: 0 0 0.5rem;
        text-indent: 1em;
      }
      .ws-body h3 {
        font-size: 12pt;
        margin: 0.8rem 0 0.3rem;
        padding-bottom: 2px;
        border-bottom: 1px dashed #888;
      }
      .ws-body rt {
        font-size: 0.5em;
        color: #555;
      }
      .ws-body blockquote.song {
        margin: 0.5rem 1.2rem;
        padding: 0.3rem 0.8rem;
        border-left: 3px solid #b85c4a;
        background: #f9f6ed;
        font-style: italic;
      }

      .ws-questions {
        margin: 0;
        padding: 0;
        list-style: none;
        counter-reset: ws-q;
      }
      .ws-question {
        counter-increment: ws-q;
        margin-bottom: 1rem;
        page-break-inside: avoid;
      }
      .ws-question__text {
        font-family: var(--font-sans);
        font-size: 10.5pt;
        line-height: 1.6;
        margin: 0 0 0.5rem;
      }
      .ws-question__text::before {
        content: "問 " counter(ws-q) ".  ";
        font-family: var(--font-sans);
        font-weight: 700;
        color: #b85c4a;
        margin-right: 0.2rem;
      }
      .ws-answer {
        height: 4.5em;
        border: 1px solid #888;
        border-radius: 4px;
        background:
          repeating-linear-gradient(
            transparent,
            transparent calc(1.5em - 1px),
            #d0d0d0 calc(1.5em - 1px),
            #d0d0d0 1.5em
          );
        background-position: 0 0.4em;
      }

      .ws-footer {
        margin-top: 1.5rem;
        padding-top: 0.5rem;
        border-top: 1px solid #999;
        font-family: var(--font-sans);
        font-size: 8.5pt;
        color: #555;
        line-height: 1.5;
      }
      .ws-footer a {
        color: #555;
        text-decoration: none;
      }

      /* ─── 印刷時のスタイル ─── */
      @page {
        size: A4;
        margin: 0;
      }
      @media print {
        html, body { background: white !important; margin: 0; }
        :root[data-worksheet-mode] body { background: white !important; }
        .ws-toolbar { display: none !important; }
        .ws-page {
          margin: 0;
          padding: 18mm 16mm;
          max-width: none;
          min-height: 0;
          box-shadow: none;
          page-break-after: always;
        }
        .ws-question { page-break-inside: avoid; }
        .ws-section__title { background: #efe9d8 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      }

      @media (max-width: 600px) {
        .ws-page { padding: 12mm 8mm; font-size: 11pt; }
        .ws-title { font-size: 18pt; }
      }
    </style>
  </head>
  <body>
    <div class="ws-toolbar no-print">
      <div style="display: flex; align-items: center; gap: 0.6rem;">
        <a href={lessonUrl} title="教材ページへ戻る">← 戻る</a>
        <span class="ws-toolbar__hint">A4・縦・両面なしを推奨</span>
      </div>
      <button type="button" onclick="window.print()">印刷 ／ PDF として保存</button>
    </div>

    <article class="ws-page">
      <header class="ws-header">
        <span class="ws-header__brand">ひらく — OPEN TEXTBOOKS WORKSHEET</span>
        <span class="ws-header__meta">{stage} {d.subject} 第{d.grade}学年</span>
      </header>

      <h1 class="ws-title">{d.title}</h1>
      <p class="ws-author">
        {d.author}
        {d.author_dates && `（${d.author_dates}）`}
        {d.original_year && ` ・ ${d.original_year} 年`}
        {d.era && !d.original_year && ` ・ ${d.era}`}
      </p>

      <div class="ws-namebar">
        <div class="ws-namebar__field">
          <span>氏名</span>
          <div class="ws-namebar__line"></div>
        </div>
        <div class="ws-namebar__field" style="max-width: 110px;">
          <span>日付</span>
          <div class="ws-namebar__line"></div>
        </div>
      </div>

      <section class="ws-section">
        <h2 class="ws-section__title">本文</h2>
        <div class="ws-body story-body">
          <slot />
        </div>
      </section>

      {d.questions && d.questions.length > 0 && (
        <section class="ws-section">
          <h2 class="ws-section__title">考えてみよう（記入欄）</h2>
          <ol class="ws-questions">
            {d.questions.map((q) => (
              <li class="ws-question">
                <p class="ws-question__text">{q}</p>
                <div class="ws-answer" aria-hidden="true"></div>
              </li>
            ))}
          </ol>
        </section>
      )}

      <footer class="ws-footer">
        <p>
          出典：{d.author}「{d.title}」
          {d.original_year && `（${d.original_year}年）`}
          {d.source.url
            ? <>　／　入力：<a href={d.source.url}>{d.source.text}</a></>
            : <>　／　入力：{d.source.text}</>}
          {d.source.base && <>　／　底本：{d.source.base}</>}
        </p>
        <p>
          編集・語注・問い：CC BY 4.0 ©︎ project_procopios contributors　／　原文：パブリックドメイン
          <span style="float: right;">hiraku-5cb.pages.dev{lessonUrl}</span>
        </p>
      </footer>
    </article>
  </body>
</html>
